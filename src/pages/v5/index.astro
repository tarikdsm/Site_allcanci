---
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import { Image, getImage } from 'astro:assets';
import { empresa, numeros, contatos, redes } from '../../data/site';
import { produtos } from '../../data/produtos';
import { etapasComodato } from '../../data/comodato';
import { faq } from '../../data/faq';
import { provaSocial } from '../../data/provaSocial';
import { sustentabilidade } from '../../data/sustentabilidade';
import * as img from '../../data/imagens';
import { simular, reais, PREMISSAS } from '../../scripts/simulador-core.js';
import '../../styles/v5.css';

const base = import.meta.env.BASE_URL;
const hubUrl = base.endsWith('/') ? base : `${base}/`;
const ano = new Date().getFullYear();
const telefoneHref = `tel:+55${contatos.telefone.replace(/\D/g, '')}`;

const ogImage = await getImage({ src: img.ecoMarkerPreto, format: 'webp', width: 1200 });

// Simulador: estado inicial renderizado no servidor (funciona sem JS)
const professoresIniciais = 20;
const sim0 = simular(professoresIniciais);

// Tanque de tinta: mesma fórmula do v5.js — ALTURA_MAX 180, fundo da garrafa em y=200
// A fração é a economia do estado inicial em relação à economia no máximo do slider.
const ALTURA_MAX = 180;
const professoresMax = 200;
const economiaMax0 = simular(professoresMax).economia;
const fracao0 = economiaMax0 > 0 ? Math.max(0, sim0.economia) / economiaMax0 : 0;
const tanqueAltura0 = Math.round(ALTURA_MAX * Math.min(1, fracao0));
const tanqueY0 = 200 - tanqueAltura0;

// Marquee do hero (decorativo; versão legível fica em .visually-hidden)
const fraseMarquee = `MENOS DESCARTE — MAIS CONTROLE — RECARGA EM ${numeros.recargaSegundos}S — ${numeros.escritaKm} KM DE ESCRITA — `;

// Trilho de produtos: cor do painel + foto por produto.
// Painéis escuros (azul/preto) recebem SOMENTE fotos de fundo limpo; as fotos com
// xadrez de falsa transparência gravado (ver imagensEscurasProibidas) ficam nos
// painéis claros — e toda foto vive dentro de um estágio branco.
type PainelProduto = { cor: 'azul' | 'creme' | 'nevoa' | 'preto'; src: ImageMetadata; alt: string };
const paineisProdutos: Record<string, PainelProduto> = {
  'ink-injector': {
    cor: 'azul',
    src: img.inkInjectorAberta,
    alt: 'Máquina FILL Ink Injector azul com a tampa aberta, mostrando o refil translúcido e um pincel vermelho encaixados no interior',
  },
  'eco-marker': {
    cor: 'creme',
    src: img.ecoMarkerTrio,
    alt: 'Três pincéis recarregáveis FILL Eco Marker nas cores vermelho, preto e azul',
  },
  'master-color': {
    cor: 'nevoa',
    src: img.masterColorTrio,
    alt: 'Três frascos de 500 ml de tinta FILL Master Color nas cores azul, vermelho e preto',
  },
  'master-clean': {
    cor: 'preto',
    src: img.masterCleanAberto,
    alt: 'Estojo azul FILL Master Clean 3P aberto, guardando pincéis e um refil translúcido',
  },
  refil: {
    cor: 'creme',
    src: img.ecoMarkerPreto,
    alt: 'Pincel FILL Eco Marker preto com refil de feltro removível translúcido encaixado na base',
  },
  app: {
    cor: 'nevoa',
    src: img.moedasCredito,
    alt: 'Três moedas azuis de crédito de recarga FILL com gota de tinta em relevo',
  },
};

// Prova social: manchete gigante com palavras-chave destacadas em cores de tinta
type Trecho = { texto: string; cor?: 'azul' | 'vermelho' | 'azul-claro' };
const chavesProva: { chave: string; cor: NonNullable<Trecho['cor']> }[] = [
  { chave: '500 escolas', cor: 'azul' },
  { chave: 'pincel descartável', cor: 'vermelho' },
  { chave: 'ecossistema FILL', cor: 'azul-claro' },
];
let trechosProva: Trecho[] = [{ texto: provaSocial.texto }];
for (const { chave, cor } of chavesProva) {
  trechosProva = trechosProva.flatMap((t) => {
    if (t.cor || !t.texto.includes(chave)) return [t];
    const i = t.texto.indexOf(chave);
    return [
      { texto: t.texto.slice(0, i) },
      { texto: chave, cor },
      { texto: t.texto.slice(i + chave.length) },
    ].filter((p) => p.texto.length > 0);
  });
}

// Como funciona: cores de tinta das gotas (ciclo azul → preto → vermelho)
const coresGotas = ['azul', 'preto', 'vermelho'] as const;

const linksMenu = [
  { href: '#produtos', rotulo: 'Produtos' },
  { href: '#como-funciona', rotulo: 'Como funciona' },
  { href: '#simulador', rotulo: 'Simulador' },
  { href: '#faq', rotulo: 'FAQ' },
];
---

<Layout
  title="Allcanci Tecnologia — Tinta viva para quadro branco"
  description="Menos descarte, mais tinta: o sistema FILL da Allcanci troca pincéis descartáveis por recarga inteligente, com créditos previsíveis para escolas de todo o Brasil."
  ogImage={ogImage.src}
  bodyClass="v5"
>
  <a class="v5-pular" href="#hero">Pular para o conteúdo</a>

  <header class="v5-topo">
    <div class="v5-caixa v5-topo-linha">
      <a class="v5-wordmark" href="#hero">allcanci <span aria-hidden="true">●</span> tecnologia</a>
      <nav class="v5-nav" aria-label="Seções da página">
        <ul class="v5-menu" role="list">
          {linksMenu.map((item) => (
            <li><a href={item.href}>{item.rotulo}</a></li>
          ))}
        </ul>
      </nav>
      <a class="v5-topo-chip" href="#contato">Contato</a>
    </div>
  </header>

  <main>
    <!-- ═══ HERO — a tinta é viva: canvas de manchas sob o cursor ═══ -->
    <section id="hero" class="v5-hero" aria-labelledby="titulo-hero">
      <canvas id="tinta" class="v5-tinta" aria-hidden="true"></canvas>

      <div class="v5-caixa v5-hero-conteudo">
        <p class="v5-kicker">{empresa.nome} · {empresa.slogan}</p>
        <h1 id="titulo-hero" class="v5-colossal">
          <span class="v5-tinta-azul">TINTA</span>
          <span class="v5-tinta-preta">VIVA<span class="v5-tinta-vermelha">.</span></span>
        </h1>
        <p class="v5-hero-sub">{empresa.descricao}</p>
        <div class="v5-hero-ctas">
          <a class="v5-pilula" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">
            Falar no WhatsApp
          </a>
          <a class="v5-hero-secundario" href="#produtos">
            mergulhe no ecossistema <span aria-hidden="true">↓</span>
          </a>
        </div>
        <p class="v5-hero-dica" aria-hidden="true">passe o cursor: a tinta responde</p>
      </div>

      <p class="visually-hidden">
        Menos descarte, mais controle: recarga em {numeros.recargaSegundos} segundos
        e {numeros.escritaKm} km de escrita por recarga.
      </p>
      <div class="v5-marquee" aria-hidden="true">
        <div class="v5-marquee-track">
          <span>{fraseMarquee}{fraseMarquee}{fraseMarquee}</span>
          <span>{fraseMarquee}{fraseMarquee}{fraseMarquee}</span>
        </div>
      </div>
    </section>

    <!-- ═══ PRODUTOS — trilho horizontal full-viewport com painéis de tinta ═══ -->
    <section id="produtos" class="v5-secao v5-produtos" aria-labelledby="titulo-produtos">
      <div class="v5-caixa v5-produtos-cabeca">
        <div>
          <p class="v5-kicker">Ecossistema FILL</p>
          <h2 class="v5-titulo" id="titulo-produtos">
            <span class="v5-tinta-azul">Seis produtos.</span>
            <span class="v5-tinta-preta">Uma tinta só.</span>
          </h2>
        </div>
        <div class="v5-produtos-controles">
          <p class="v5-arraste" aria-hidden="true">arraste →</p>
          <button class="trilho-prev v5-seta" type="button" aria-label="Painel anterior">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="m14.5 5.5-6.5 6.5 6.5 6.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <button class="trilho-next v5-seta" type="button" aria-label="Próximo painel">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="m9.5 5.5 6.5 6.5-6.5 6.5" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      </div>

      <ul
        class="trilho v5-trilho"
        role="list"
        tabindex="0"
        aria-label="Vitrine de produtos FILL — use os botões, as setas do teclado ou arraste para navegar"
      >
        {produtos.map((produto, i) => {
          const painel = paineisProdutos[produto.id];
          return (
            <li class={`v5-painel v5-painel--${painel.cor}`}>
              <article class="v5-painel-grade">
                <p class="v5-painel-nome" aria-hidden="true">{produto.nome}</p>
                <div class="v5-painel-foto">
                  <Image
                    src={painel.src}
                    alt={painel.alt}
                    widths={[360, 560, 800]}
                    sizes="(min-width: 900px) 30rem, 78vw"
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />
                </div>
                <div class="v5-painel-texto">
                  <p class="v5-painel-indice">{String(i + 1).padStart(2, '0')} / {String(produtos.length).padStart(2, '0')}</p>
                  <h3>{produto.nome}</h3>
                  <p class="v5-painel-sub">{produto.subtitulo}</p>
                  <p class="v5-painel-desc">{produto.descricao}</p>
                  <ul class="v5-painel-destaques" role="list">
                    {produto.destaques.map((destaque) => (
                      <li>{destaque}</li>
                    ))}
                  </ul>
                </div>
              </article>
            </li>
          );
        })}
      </ul>
    </section>

    <!-- ═══ COMO FUNCIONA — 6 gotas numa linha do tempo que respinga ═══ -->
    <section id="como-funciona" class="v5-secao v5-como" aria-labelledby="titulo-como">
      <div class="v5-caixa">
        <p class="v5-kicker">Comodato em 6 gotas</p>
        <h2 class="v5-titulo" id="titulo-como">
          <span class="v5-tinta-preta">Do diagnóstico</span>
          <span class="v5-tinta-azul">à recarga sem fim.</span>
        </h2>

        <ol class="v5-etapas" role="list">
          {etapasComodato.map((etapa, i) => (
            <li class="v5-etapa">
              <span class={`v5-gota-blob v5-gota-blob--${coresGotas[i % coresGotas.length]}`} aria-hidden="true">{i + 1}</span>
              <h3>{etapa.titulo}</h3>
              <p>{etapa.texto}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ═══ SIMULADOR — o tanque de tinta que enche com a economia ═══ -->
    <section id="simulador" class="v5-secao v5-simulador" aria-labelledby="titulo-simulador">
      <div class="v5-caixa">
        <p class="v5-kicker">Simulador de economia</p>
        <h2 class="v5-titulo" id="titulo-simulador">
          <span class="v5-tinta-preta">Mova o slider.</span>
          <span class="v5-tinta-azul">A tinta faz as contas.</span>
        </h2>

        <div class="v5-sim-grade">
          <div class="v5-sim-controles">
            <label class="v5-sim-label" for="sim-professores">Professores na instituição</label>
            <div class="v5-sim-linha">
              <input
                type="range"
                id="sim-professores"
                min="1"
                max="200"
                step="1"
                value={professoresIniciais}
              />
              <input
                type="number"
                id="sim-professores-num"
                min="1"
                max="999"
                value={professoresIniciais}
                aria-label="Número de professores"
              />
            </div>

            <dl class="v5-sim-numeros">
              <div class="v5-sim-heroi">
                <dt>economia estimada por ano</dt>
                <dd id="sim-economia">{reais(sim0.economia)}</dd>
              </div>
              <div class="v5-sim-dado">
                <dt>pincéis descartáveis evitados</dt>
                <dd id="sim-descartaveis">{sim0.descartaveis.toLocaleString('pt-BR')}</dd>
              </div>
              <div class="v5-sim-dado">
                <dt>plástico que não vira lixo</dt>
                <dd id="sim-plastico">{sim0.plasticoEvitadoKg.toLocaleString('pt-BR')} kg</dd>
              </div>
            </dl>

            <p class="v5-sim-apoio">
              São <strong id="sim-recargas">{sim0.recargasAno.toLocaleString('pt-BR')}</strong> recargas por ano,
              com investimento de <strong id="sim-custo-fill">{reais(sim0.custoFill)}</strong> em créditos FILL.
            </p>

            <p class="v5-sim-premissas">
              Premissas do cálculo: {PREMISSAS.recargasPorProfessorAno} recargas por professor/ano ·
              crédito de recarga a {reais(PREMISSAS.precoCreditoReais)} · 1 recarga rende
              ~{PREMISSAS.kmPorRecarga} km de escrita · pincel descartável rende
              ~{PREMISSAS.metrosPorDescartavel} m e custa {reais(PREMISSAS.precoDescartavelReais)} ·
              ~{PREMISSAS.kgPlasticoPorDescartavel * 1000} g de plástico por descartável.
            </p>
          </div>

          <figure class="v5-tanque-figura">
            <svg class="v5-tanque-svg" viewBox="0 0 140 224" aria-hidden="true" focusable="false">
              <defs>
                <clipPath id="v5-garrafa-clip">
                  <path d="M56 22 L56 36 C56 50 26 54 26 72 L26 186 A14 14 0 0 0 40 200 L100 200 A14 14 0 0 0 114 186 L114 72 C114 54 84 50 84 36 L84 22 Z" />
                </clipPath>
              </defs>
              <rect class="v5-garrafa-tampa" x="52" y="4" width="36" height="18" rx="4"></rect>
              <g clip-path="url(#v5-garrafa-clip)">
                <rect class="v5-garrafa-fundo" x="20" y="16" width="100" height="190"></rect>
                <rect id="sim-tanque" x="20" y={tanqueY0} width="100" height={tanqueAltura0}></rect>
              </g>
              <path
                class="v5-garrafa-contorno"
                d="M56 22 L56 36 C56 50 26 54 26 72 L26 186 A14 14 0 0 0 40 200 L100 200 A14 14 0 0 0 114 186 L114 72 C114 54 84 50 84 36 L84 22 Z"
              ></path>
              <g class="v5-garrafa-marcas">
                <line x1="100" y1="90" x2="112" y2="90"></line>
                <line x1="100" y1="130" x2="112" y2="130"></line>
                <line x1="100" y1="170" x2="112" y2="170"></line>
              </g>
            </svg>
            <figcaption class="v5-tanque-legenda">
              Tanque de economia — garrafa FILL Master Color de 500 ml. A tinta cresce com
              a sua escola: quanto mais professores no slider, mais cheio o tanque.
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ═══ PROVA SOCIAL — manchete com palavras em tinta + selos em marquee ═══ -->
    <section id="prova-social" class="v5-secao v5-prova" aria-labelledby="titulo-prova">
      <div class="v5-caixa">
        <p class="v5-kicker">{numeros.escolas} escolas · {provaSocial.titulo}</p>
        <h2 class="visually-hidden" id="titulo-prova">{provaSocial.titulo}</h2>
        <p class="v5-manchete">
          {trechosProva.map((t) =>
            t.cor ? <em class={`v5-chave v5-chave--${t.cor}`}>{t.texto}</em> : t.texto
          )}
        </p>
      </div>

      <div class="v5-selos-faixa">
        <div class="v5-selos-track">
          <ul class="v5-selos-lista" role="list" aria-label="Selos Allcanci">
            {provaSocial.selos.map((selo) => (
              <li>{selo}</li>
            ))}
          </ul>
          <ul class="v5-selos-lista v5-selos-copia" role="list" aria-hidden="true">
            {provaSocial.selos.map((selo) => (
              <li>{selo}</li>
            ))}
          </ul>
        </div>
      </div>

      {provaSocial.depoimentos.length > 0 && (
        <div class="v5-caixa">
          <ul class="v5-depoimentos" role="list">
            {provaSocial.depoimentos.map((dep) => (
              <li>
                <blockquote>
                  <p>{dep.citacao}</p>
                  <footer>{dep.autor} — {dep.instituicao}</footer>
                </blockquote>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>

    <!-- ═══ SUSTENTABILIDADE — painel preto com acentos verdes ═══ -->
    <section id="sustentabilidade" class="v5-secao v5-sustenta" aria-labelledby="titulo-sustenta">
      <div class="v5-caixa">
        <p class="v5-kicker v5-kicker--verde">Sustentabilidade</p>
        <h2 class="v5-titulo v5-sustenta-titulo" id="titulo-sustenta">{sustentabilidade.titulo}</h2>
        <p class="v5-sustenta-texto">{sustentabilidade.texto}</p>

        <ul class="v5-pontos" role="list">
          {sustentabilidade.pontos.map((ponto) => (
            <li class="v5-ponto">
              <span class="v5-ponto-gota" aria-hidden="true"></span>
              <h3>{ponto.titulo}</h3>
              <p>{ponto.texto}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ═══ FAQ — accordion com numeração gigante fantasma ═══ -->
    <section id="faq" class="v5-secao v5-faq" aria-labelledby="titulo-faq">
      <div class="v5-caixa">
        <p class="v5-kicker">FAQ</p>
        <h2 class="v5-titulo" id="titulo-faq">
          <span class="v5-tinta-preta">Perguntas que</span>
          <span class="v5-tinta-azul">sempre pingam.</span>
        </h2>

        <div class="v5-faq-lista">
          {faq.map((item, i) => (
            <details class="v5-faq-item">
              <summary>
                <span class="v5-faq-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                {item.pergunta}
                <span class="v5-faq-icone" aria-hidden="true">+</span>
              </summary>
              <p class="v5-faq-resposta">{item.resposta}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ CONTATO — o mergulho final no azul ═══ -->
    <section id="contato" class="v5-contato" aria-labelledby="titulo-contato">
      <div class="v5-caixa v5-contato-conteudo">
        <p class="v5-contato-wordmark">allcanci <span aria-hidden="true">●</span> tecnologia</p>
        <h2 id="titulo-contato" class="v5-contato-titulo">Pronto para aposentar o descartável?</h2>
        <p class="v5-contato-sub">
          Proposta de comodato sob medida, com entrega em até {numeros.entregaDiasUteis} dias
          úteis para todo o Brasil.
        </p>

        <a class="v5-cta-final" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">
          Chamar no WhatsApp <span aria-hidden="true">↗</span>
        </a>

        <ul class="v5-contato-info" role="list">
          <li><a href={telefoneHref}>{contatos.telefone}</a></li>
          <li><a href={`mailto:${contatos.email}`}>{contatos.email}</a></li>
          <li>{contatos.endereco}</li>
        </ul>

        <ul class="v5-redes" role="list" aria-label="Redes sociais">
          {redes.map((rede) => (
            <li>
              <a href={rede.url} target="_blank" rel="noopener noreferrer">{rede.nome}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <footer class="v5-rodape">
    <div class="v5-caixa v5-rodape-linha">
      <p>© {ano} {empresa.nome} — {empresa.cidade}</p>
      <p><a href={hubUrl}>Ver as 5 propostas</a></p>
    </div>
  </footer>

  <div class="v5-gota" aria-hidden="true"></div>

  <script src="../../scripts/v5.js"></script>
</Layout>
