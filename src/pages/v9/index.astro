---
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import { Image, getImage } from 'astro:assets';
import { empresa, numeros, contatos, redes } from '../../data/site';
import { produtos } from '../../data/produtos';
import { etapasComodato } from '../../data/comodato';
import { faq } from '../../data/faq';
import { provaSocial } from '../../data/provaSocial';
import { sustentabilidade } from '../../data/sustentabilidade';
import * as img from '../../data/imagens';
import { simular, reais, PREMISSAS } from '../../scripts/simulador-core.js';
import render3d from '../../assets/3d/maquina-fill-render.png';
import renderTqDir from '../../assets/3d/maquina-fill-tq-dir.png';
import '@fontsource-variable/outfit/index.css';
import '@fontsource-variable/dm-sans/index.css';
import '../../styles/v9.css';

const base = import.meta.env.BASE_URL;
const ano = new Date().getFullYear();

// URL do modelo 3D otimizado (asset estático em public/)
const glbUrl = `${base}/models/maquina_fill_web.glb`;

// Poster do model-viewer (render transparente → webp) — também usado como OG
const poster = await getImage({ src: render3d, format: 'webp', width: 1200 });

// Estado inicial do simulador (renderizado no servidor para funcionar sem JS)
const professoresIniciais = 20;
const sim0 = simular(professoresIniciais);

// Chips de vidro do hero — valores vindos de src/data/site.ts
const stats = [
  { valor: numeros.escolas.replace(/\D/g, ''), prefixo: '+', sufixo: '', texto: numeros.escolas, rotulo: 'escolas já atendidas' },
  { valor: String(numeros.recargaSegundos), prefixo: '', sufixo: 's', texto: `${numeros.recargaSegundos}s`, rotulo: 'por recarga automática' },
  { valor: String(numeros.escritaKm), prefixo: '', sufixo: ' km', texto: `${numeros.escritaKm} km`, rotulo: 'de escrita por recarga' },
  { valor: String(numeros.entregaDiasUteis), prefixo: '', sufixo: '', texto: String(numeros.entregaDiasUteis), rotulo: 'dias úteis até a entrega' },
];

// Fotos dos produtos — sempre sobre palco branco sólido dentro dos cartões de
// vidro (as imagens com xadrez gravado exigem fundo claro).
const fotosProdutos: Record<string, { src: ImageMetadata; alt: string }> = {
  'ink-injector': {
    src: img.inkInjector,
    alt: 'Máquina FILL Ink Injector vista de frente, com encaixes de recarga nas cores azul, preto e vermelho e visor digital aceso',
  },
  'eco-marker': {
    src: img.ecoMarkerTrio,
    alt: 'Três pincéis recarregáveis FILL Eco Marker nas cores vermelho, preto e azul',
  },
  'master-color': {
    src: img.masterColorTrio,
    alt: 'Três frascos de 500 ml de tinta FILL Master Color nas cores azul, vermelho e preto',
  },
  'master-clean': {
    src: img.masterClean,
    alt: 'Estojo apagador FILL Master Clean 3P na cor azul, com feltro apagador na base',
  },
  refil: {
    src: img.ecoMarkerPreto,
    alt: 'Pincel FILL Eco Marker preto com refil de feltro removível translúcido encaixado na base',
  },
  app: {
    src: img.moedasCredito,
    alt: 'Três moedas azuis de crédito de recarga FILL com gota de tinta em relevo',
  },
};

const linksMenu = [
  { href: '#produtos', rotulo: 'Produtos' },
  { href: '#como-funciona', rotulo: 'Como funciona' },
  { href: '#simulador', rotulo: 'Simulador' },
  { href: '#sustentabilidade', rotulo: 'Sustentabilidade' },
  { href: '#faq', rotulo: 'FAQ' },
  { href: '#contato', rotulo: 'Contato' },
];

const telefoneHref = `tel:+55${contatos.telefone.replace(/\D/g, '')}`;

const altModelo =
  'Modelo 3D interativo da máquina FILL Ink Injector: corpo preto fosco, encaixes de recarga azul, preto e vermelho no topo, visor azul aceso e logotipo dourado na placa frontal';
---

<Layout
  title="Allcanci Tecnologia — O quadro branco ficou leve"
  description="Sistema FILL da Allcanci Tecnologia: recarga automática de pincéis de quadro branco em 22 segundos, comodato sem investimento inicial — e realidade aumentada para ver a máquina em tamanho real na sua mesa."
  ogImage={poster.src}
  bodyClass="v9"
>
  <a class="v9-skip" href="#hero">Pular para o conteúdo</a>

  <!-- Auroras desfocadas fixas atrás de todo o conteúdo -->
  <div class="v9-auroras" aria-hidden="true">
    <span class="v9-aurora v9-aurora--teal"></span>
    <span class="v9-aurora v9-aurora--peri"></span>
    <span class="v9-aurora v9-aurora--blush"></span>
  </div>

  <header class="v9-topo">
    <div class="v9-caixa">
      <div class="v9-topo-linha v9-vidro">
        <a class="v9-wordmark" href="#hero">
          <span class="v9-gota" aria-hidden="true"></span>
          allcanci<span>&nbsp;tecnologia</span>
        </a>
        <nav class="v9-nav" aria-label="Seções da página">
          <ul class="v9-menu" role="list">
            {linksMenu.map((item) => (
              <li><a href={item.href}>{item.rotulo}</a></li>
            ))}
          </ul>
        </nav>
        <a
          class="v9-botao v9-botao--primario v9-botao--mini"
          href={contatos.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </header>

  <main>
    <!-- ═══ HERO ═══ -->
    <section id="hero" class="v9-hero" aria-labelledby="titulo-hero">
      <div class="v9-caixa v9-hero-conteudo">
        <p class="v9-kicker">{empresa.nome} · {empresa.cidade}</p>
        <h1 id="titulo-hero">
          O quadro branco <span class="v9-grifo">ficou leve.</span>
        </h1>
        <p class="v9-sub">{empresa.descricao}</p>

        <div class="v9-hero-ctas">
          <a
            class="v9-botao v9-botao--primario"
            href={contatos.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
            </svg>
            Falar no WhatsApp
          </a>
          <a class="v9-botao v9-botao--fantasma" href="#simulador">Simular a economia</a>
        </div>

        <div class="v9-palco">
          <div class="v9-flutua" id="v9-flutua">
            <model-viewer
              id="v9-mv"
              class="v9-mv"
              src={glbUrl}
              alt={altModelo}
              poster={poster.src}
              camera-controls
              touch-action="pan-y"
              ar
              ar-modes="webxr scene-viewer"
              ar-scale="fixed"
              shadow-intensity="0.8"
              exposure="1.1"
              interaction-prompt="none"
              interpolation-decay="300"
              camera-orbit="65deg 78deg 105%"
            ></model-viewer>
          </div>
          <div class="v9-palco-sombra" aria-hidden="true"></div>
          <p class="v9-palco-legenda">FILL Ink Injector — arraste para girar, role para orbitar</p>

          <div class="v9-ar-linha">
            <button class="v9-botao v9-botao--ar" id="v9-ar" type="button" hidden>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M4 8V5.5A1.5 1.5 0 0 1 5.5 4H8M16 4h2.5A1.5 1.5 0 0 1 20 5.5V8M20 16v2.5a1.5 1.5 0 0 1-1.5 1.5H16M8 20H5.5A1.5 1.5 0 0 1 4 18.5V16" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                <path d="m12 7.2 4 2.3v4.9l-4 2.4-4-2.4V9.5l4-2.3Zm0 0v4.7m4-2.4-4 2.4m-4-2.4 4 2.4" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
              </svg>
              Ver em tamanho real na sua mesa
            </button>
            <span class="v9-ar-chip" id="v9-ar-chip" hidden>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="7" y="2.8" width="10" height="18.4" rx="2.4" stroke="currentColor" stroke-width="1.7" />
                <path d="M10.4 5.4h3.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
              </svg>
              Abra no celular para ver em AR na sua mesa
            </span>
          </div>
        </div>

        <ul class="v9-stats" role="list">
          {stats.map((stat) => (
            <li class="v9-stat v9-vidro">
              <span
                class="v9-stat-num"
                data-contador={stat.valor}
                data-prefixo={stat.prefixo}
                data-sufixo={stat.sufixo}
              >{stat.texto}</span>
              <span class="v9-stat-rotulo">{stat.rotulo}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ═══ PRODUTOS ═══ -->
    <section id="produtos" class="v9-secao" aria-labelledby="titulo-produtos">
      <div class="v9-caixa">
        <p class="v9-kicker">Ecossistema FILL</p>
        <h2 class="v9-titulo" id="titulo-produtos">Seis peças que tiram o peso da rotina</h2>
        <p class="v9-sub">
          Da máquina de recarga ao aplicativo de gestão: cada componente foi projetado para
          funcionar em conjunto — e aposentar o pincel descartável.
        </p>

        <ul class="v9-produtos-grade" role="list">
          {produtos.map((produto, i) => {
            const foto = fotosProdutos[produto.id];
            return (
              <li class="v9-produto v9-vidro" data-reveal style={`--d:${(i % 3) * 70}ms`}>
                {foto && (
                  <div class="v9-produto-foto">
                    <Image
                      src={foto.src}
                      alt={foto.alt}
                      widths={[320, 480, 680]}
                      sizes="(min-width: 1024px) 340px, (min-width: 640px) 46vw, 88vw"
                    />
                  </div>
                )}
                <span class="v9-produto-tag">{produto.subtitulo}</span>
                <h3>{produto.nome}</h3>
                <p class="v9-produto-desc">{produto.descricao}</p>
                <ul class="v9-destaques" role="list">
                  {produto.destaques.map((destaque) => (
                    <li>{destaque}</li>
                  ))}
                </ul>
              </li>
            );
          })}
        </ul>
      </div>
    </section>

    <!-- ═══ COMO FUNCIONA ═══ -->
    <section id="como-funciona" class="v9-secao" aria-labelledby="titulo-como">
      <div class="v9-caixa">
        <p class="v9-kicker">Comodato em 6 etapas</p>
        <h2 class="v9-titulo" id="titulo-como">Do diagnóstico à recarga contínua</h2>
        <p class="v9-sub">
          Sem investimento inicial em equipamento: a Allcanci instala, treina e acompanha —
          sua equipe só usa.
        </p>

        <ol class="v9-etapas" role="list">
          {etapasComodato.map((etapa, i) => (
            <li class="v9-etapa" data-reveal style={`--d:${i * 60}ms`}>
              <span class="v9-etapa-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <h3>{etapa.titulo}</h3>
              <p>{etapa.texto}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ═══ SIMULADOR ═══ -->
    <section id="simulador" class="v9-secao" aria-labelledby="titulo-simulador">
      <div class="v9-caixa">
        <p class="v9-kicker">Simulador de economia</p>
        <h2 class="v9-titulo" id="titulo-simulador">Quanto a sua instituição economiza?</h2>
        <p class="v9-sub">
          Deslize o controle e veja a projeção anual flutuar em tempo real — recargas, custos
          e plástico que deixa de virar lixo.
        </p>

        <div class="v9-painel v9-vidro">
          <div class="v9-painel-corpo">
            <div>
              <label class="v9-painel-label" for="sim-professores">
                Professores na instituição
              </label>
              <div class="v9-painel-controle-linha">
                <input
                  type="range"
                  id="sim-professores"
                  min="1"
                  max="200"
                  step="1"
                  value={professoresIniciais}
                />
                <input
                  type="number"
                  id="sim-professores-num"
                  min="1"
                  max="999"
                  value={professoresIniciais}
                  aria-label="Número de professores"
                />
              </div>
              <p class="v9-premissas">
                Premissas do cálculo: {PREMISSAS.recargasPorProfessorAno} recargas por
                professor/ano · crédito de recarga a {reais(PREMISSAS.precoCreditoReais)} · 1
                recarga rende ~{PREMISSAS.kmPorRecarga} km de escrita · pincel descartável rende
                ~{PREMISSAS.metrosPorDescartavel} m e custa {reais(PREMISSAS.precoDescartavelReais)} ·
                ~{PREMISSAS.kgPlasticoPorDescartavel * 1000} g de plástico por descartável.
              </p>
            </div>

            <dl class="v9-leituras">
              <div class="v9-leitura">
                <dt>Recargas por ano</dt>
                <dd id="sim-recargas">{sim0.recargasAno.toLocaleString('pt-BR')}</dd>
              </div>
              <div class="v9-leitura">
                <dt>Investimento FILL/ano</dt>
                <dd id="sim-custo-fill">{reais(sim0.custoFill)}</dd>
              </div>
              <div class="v9-leitura">
                <dt>Descartáveis evitados</dt>
                <dd id="sim-descartaveis">{sim0.descartaveis.toLocaleString('pt-BR')}</dd>
              </div>
              <div class="v9-leitura">
                <dt>Plástico evitado</dt>
                <dd id="sim-plastico">{sim0.plasticoEvitadoKg.toLocaleString('pt-BR')} kg</dd>
              </div>
              <div class="v9-leitura v9-leitura--destaque">
                <dt>Economia estimada/ano</dt>
                <dd id="sim-economia">{reais(sim0.economia)}</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PROVA SOCIAL ═══ -->
    <section id="prova-social" class="v9-secao" aria-labelledby="titulo-prova">
      <div class="v9-caixa">
        <p class="v9-kicker">Confiança</p>
        <h2 class="v9-titulo" id="titulo-prova">{provaSocial.titulo}</h2>
        <p class="v9-sub">{provaSocial.texto}</p>

        <ul class="v9-selos" role="list">
          {provaSocial.selos.map((selo, i) => (
            <li class="v9-selo" data-reveal style={`--d:${(i % 3) * 60}ms`}>
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="8.6" stroke="currentColor" stroke-width="1.5" />
                <path d="m6.2 10.3 2.5 2.5 5.1-5.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {selo}
            </li>
          ))}
        </ul>

        {provaSocial.depoimentos.length > 0 && (
          <ul class="v9-depoimentos" role="list">
            {provaSocial.depoimentos.map((dep) => (
              <li class="v9-depoimento v9-vidro">
                <blockquote>
                  <p>{dep.citacao}</p>
                  <footer>
                    {dep.autor} — {dep.instituicao}
                  </footer>
                </blockquote>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

    <!-- ═══ SUSTENTABILIDADE ═══ -->
    <section id="sustentabilidade" class="v9-secao v9-verde" aria-labelledby="titulo-sustentabilidade">
      <div class="v9-caixa">
        <div class="v9-verde-grade">
          <div class="v9-verde-conteudo">
            <p class="v9-kicker v9-kicker--verde">Sustentabilidade</p>
            <h2 class="v9-titulo" id="titulo-sustentabilidade">{sustentabilidade.titulo}</h2>
            <p class="v9-sub">{sustentabilidade.texto}</p>

            <ul class="v9-verde-lista" role="list">
              {sustentabilidade.pontos.map((ponto, i) => (
                <li class="v9-verde-card v9-vidro" data-reveal style={`--d:${(i % 2) * 70}ms`}>
                  <h3>
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M5 19C5 10 10 5 19 5c0 9-5 14-14 14Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                      <path d="M5 19c3-5.5 6.5-9 10-10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                    </svg>
                    {ponto.titulo}
                  </h3>
                  <p>{ponto.texto}</p>
                </li>
              ))}
            </ul>
          </div>

          <div class="v9-verde-render" aria-hidden="true">
            <Image
              src={renderTqDir}
              alt=""
              widths={[360, 520, 720]}
              sizes="(min-width: 1024px) 24rem, 60vw"
            />
            <span class="v9-verde-render-sombra"></span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ FAQ ═══ -->
    <section id="faq" class="v9-secao" aria-labelledby="titulo-faq">
      <div class="v9-caixa">
        <p class="v9-kicker">FAQ</p>
        <h2 class="v9-titulo" id="titulo-faq">Perguntas frequentes</h2>
        <p class="v9-sub">
          O que escolas e instituições mais perguntam antes de adotar o ecossistema FILL.
        </p>

        <div class="v9-faq-lista">
          {faq.map((item) => (
            <details class="v9-vidro">
              <summary>
                {item.pergunta}
                <span class="v9-faq-mais" aria-hidden="true">+</span>
              </summary>
              <p class="v9-faq-resposta">{item.resposta}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ CONTATO ═══ -->
    <section id="contato" class="v9-secao" aria-labelledby="titulo-contato">
      <div class="v9-caixa">
        <div class="v9-contato-card">
          <h2 id="titulo-contato">Deixe a sua instituição mais leve também</h2>
          <p>
            Fale com a equipe da {empresa.nome} e receba uma proposta de comodato sob medida —
            entrega em até {numeros.entregaDiasUteis} dias úteis para todo o Brasil.
          </p>

          <div class="v9-contato-cta">
            <a
              class="v9-botao v9-botao--branco"
              href={contatos.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
              </svg>
              Chamar no WhatsApp
            </a>
          </div>

          <ul class="v9-contato-lista" role="list">
            <li>
              <a class="v9-chip" href={`mailto:${contatos.email}`}>{contatos.email}</a>
            </li>
            <li>
              <a class="v9-chip" href={telefoneHref}>{contatos.telefone}</a>
            </li>
          </ul>

          <address>{contatos.endereco}</address>

          <ul class="v9-contato-redes" role="list">
            {redes.map((rede) => (
              <li>
                <a class="v9-chip" href={rede.url} target="_blank" rel="noopener noreferrer">
                  {rede.nome}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </main>

  <footer class="v9-rodape">
    <div class="v9-caixa">
      <div class="v9-rodape-grade">
        <div>
          <p class="v9-rodape-marca">allcanci<span>&nbsp;tecnologia</span></p>
          <p class="v9-rodape-slogan">{empresa.slogan}. {empresa.descricao}</p>
        </div>
        <div>
          <h2>Contato</h2>
          <ul role="list">
            <li><a href={`mailto:${contatos.email}`}>{contatos.email}</a></li>
            <li>
              <a href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">
                WhatsApp — {contatos.telefone}
              </a>
            </li>
            <li>{contatos.endereco}</li>
          </ul>
        </div>
        <div>
          <h2>Redes</h2>
          <ul role="list">
            {redes.map((rede) => (
              <li>
                <a href={rede.url} target="_blank" rel="noopener noreferrer">{rede.nome}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <div class="v9-rodape-nota">
        <p>© {ano} {empresa.nome} — {empresa.cidade}</p>
        <p><a href={`${base}/`}>Ver as 10 propostas de design</a></p>
      </div>
    </div>
  </footer>

  <script src="../../scripts/v9.js"></script>
</Layout>
