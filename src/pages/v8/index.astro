---
import type { ImageMetadata } from 'astro';
import '@fontsource-variable/bricolage-grotesque/index.css';
import '@fontsource-variable/space-grotesk/index.css';
import Layout from '../../layouts/Layout.astro';
import { Image, getImage } from 'astro:assets';
import { empresa, numeros, contatos, redes } from '../../data/site';
import { produtos } from '../../data/produtos';
import { etapasComodato } from '../../data/comodato';
import { faq } from '../../data/faq';
import { provaSocial } from '../../data/provaSocial';
import { sustentabilidade } from '../../data/sustentabilidade';
import * as img from '../../data/imagens';
import { simular, reais, PREMISSAS } from '../../scripts/simulador-core.js';
import render3d from '../../assets/3d/maquina-fill-render.png';
import topo3d from '../../assets/3d/maquina-fill-topo.png';
import '../../styles/v8.css';

const base = import.meta.env.BASE_URL;
const ano = new Date().getFullYear();

// Modelo 3D servido como asset estático + poster/OG a partir do render frontal
const glbUrl = `${base}/models/maquina_fill_web.glb`;
const poster = await getImage({ src: render3d, format: 'webp', width: 1000 });
const ogImage = await getImage({ src: render3d, format: 'webp', width: 1200 });

// Estado inicial do simulador (renderizado no servidor para funcionar sem JS)
const professoresIniciais = 20;
const sim0 = simular(professoresIniciais);

// Fita marquee — fatos vindos de src/data (duplicada com aria-hidden para o loop)
const fatosMarquee = [
  `RECARGA EM ${numeros.recargaSegundos}s`,
  `${numeros.escolas} ESCOLAS`,
  `${numeros.escritaKm} KM DE ESCRITA`,
  `${reais(numeros.precoCreditoReais)} O CRÉDITO`,
  `ENTREGA EM ${numeros.entregaDiasUteis} DIAS ÚTEIS`,
  'TECNOLOGIA PATENTEADA',
];

// Fotos dos produtos — sempre em palcos BRANCOS (xadrez gravado seguro)
const fotosProdutos: Record<string, { src: ImageMetadata; alt: string }> = {
  'ink-injector': {
    src: img.inkInjector,
    alt: 'Máquina FILL Ink Injector vista de frente, com encaixes de recarga nas cores azul, preto e vermelho e visor digital aceso',
  },
  'eco-marker': {
    src: img.ecoMarkerTrio,
    alt: 'Três pincéis recarregáveis FILL Eco Marker nas cores vermelho, preto e azul',
  },
  'master-color': {
    src: img.masterColorTrio,
    alt: 'Três frascos de 500 ml de tinta FILL Master Color nas cores azul, vermelho e preto',
  },
  'master-clean': {
    src: img.masterClean,
    alt: 'Estojo apagador FILL Master Clean 3P na cor azul, com feltro apagador na base',
  },
  refil: {
    src: img.ecoMarkerPreto,
    alt: 'Pincel FILL Eco Marker preto com refil de feltro removível translúcido encaixado na base',
  },
  app: {
    src: img.moedasCredito,
    alt: 'Três moedas azuis de crédito de recarga FILL com gota de tinta em relevo',
  },
};

// Cor de cada card de produto (cards em cores alternadas)
const corProduto: Record<string, string> = {
  'ink-injector': 'violeta',
  'eco-marker': 'acido',
  'master-color': 'rosa',
  'master-clean': 'papel',
  refil: 'acido',
  app: 'violeta',
};

// Cores dos bottons da prova social e das barras do FAQ
const corSelo = ['acido', 'rosa', 'violeta', 'branco', 'papel', 'acido'];
const corFaq = ['acido', 'rosa', 'branco', 'papel'];

const linksMenu = [
  { href: '#produtos', rotulo: 'Produtos' },
  { href: '#como-funciona', rotulo: 'Como funciona' },
  { href: '#simulador', rotulo: 'Simulador' },
  { href: '#sustentabilidade', rotulo: 'Sustentabilidade' },
  { href: '#faq', rotulo: 'FAQ' },
  { href: '#contato', rotulo: 'Contato' },
];

const telefoneHref = `tel:+55${contatos.telefone.replace(/\D/g, '')}`;
---

<Layout
  title="Allcanci Tecnologia — Chega de pincel no lixo"
  description="Quiosque FILL da Allcanci Tecnologia: gire a máquina Ink Injector em 3D, veja a recarga de 22 segundos e simule quanto a sua escola economiza ao aposentar o pincel descartável."
  ogImage={ogImage.src}
  bodyClass="v8"
>
  <a class="v8-skip" href="#hero">Pular para o conteúdo</a>

  <header class="v8-topo">
    <div class="v8-caixa v8-topo-linha">
      <a class="v8-wordmark" href="#hero">
        allcanci<span>&nbsp;tecnologia</span>
      </a>
      <nav class="v8-nav" aria-label="Seções da página">
        <ul class="v8-menu" role="list">
          {linksMenu.map((item) => (
            <li><a href={item.href}>{item.rotulo}</a></li>
          ))}
        </ul>
      </nav>
      <a
        class="v8-botao v8-botao--rosa v8-botao--mini"
        href={contatos.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" />
        </svg>
        WhatsApp
      </a>
    </div>
  </header>

  <main>
    <!-- ═══ HERO ═══ -->
    <section id="hero" class="v8-hero" aria-labelledby="titulo-hero">
      <div class="v8-caixa v8-hero-grade">
        <div class="v8-hero-texto">
          <p class="v8-kicker v8-kicker--hero">{empresa.nome} · {empresa.cidade}</p>
          <h1 id="titulo-hero" class="v8-manchete">
            <span class="v8-manchete-linha v8-manchete-linha--solida">Chega de</span>
            <span class="v8-manchete-linha v8-manchete-linha--vazada">pincel</span>
            <span class="v8-manchete-linha v8-manchete-linha--acida">no lixo</span>
          </h1>
          <p class="v8-hero-sub">{empresa.descricao}</p>
          <div class="v8-hero-ctas">
            <a
              class="v8-botao v8-botao--acido"
              href={contatos.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" />
              </svg>
              Falar no WhatsApp
            </a>
            <a class="v8-botao v8-botao--branco" href="#simulador">Simular a economia</a>
          </div>
        </div>

        <!-- A máquina como brinquedo dentro de uma caixa gráfica -->
        <div class="v8-brinquedo">
          <p class="v8-brinquedo-rotulo">
            FILL Ink Injector
            <span aria-hidden="true">item nº 01</span>
          </p>
          <div class="v8-brinquedo-visor">
            <model-viewer
              id="v8-maquina"
              src={glbUrl}
              alt="Modelo 3D interativo da máquina FILL Ink Injector: corpo preto fosco, encaixes de recarga azul, preto e vermelho no topo, visor azul aceso e logotipo dourado na frente"
              poster={poster.src}
              loading="lazy"
              camera-controls
              camera-orbit="115deg 75deg auto"
              disable-zoom
              shadow-intensity="1.2"
              exposure="1"
              interaction-prompt="none"
              interpolation-decay="200"
            ></model-viewer>
            <span class="v8-adesivo v8-adesivo--gire" aria-hidden="true">GIRE-ME <span class="v8-adesivo-seta">⟳</span></span>
          </div>
          <div class="v8-brinquedo-base">
            <p class="v8-etiqueta-pendurada">o brinquedo favorito das {numeros.escolas} escolas</p>
            <button type="button" id="v8-giro" class="v8-botao v8-botao--preto v8-botao--giro">
              DAR UM GIRO <span aria-hidden="true">⟳</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Fita marquee com os fatos -->
      <div class="v8-marquee">
        <ul class="v8-marquee-trilho" role="list">
          {fatosMarquee.map((fato) => (
            <li>{fato} <span class="v8-marquee-estrela" aria-hidden="true">★</span></li>
          ))}
        </ul>
        <ul class="v8-marquee-trilho" role="list" aria-hidden="true">
          {fatosMarquee.map((fato) => (
            <li>{fato} <span class="v8-marquee-estrela">★</span></li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ═══ PRODUTOS ═══ -->
    <section id="produtos" class="v8-secao v8-secao--papel" aria-labelledby="titulo-produtos">
      <div class="v8-caixa">
        <p class="v8-kicker">Ecossistema FILL</p>
        <h2 class="v8-titulo" id="titulo-produtos">Seis peças, uma banquinha completa</h2>
        <p class="v8-sub">
          Da máquina de recarga ao aplicativo de gestão: cada componente foi projetado para
          funcionar em conjunto — e acabar com o pincel descartável.
        </p>

        <ul class="v8-produtos-grade" role="list">
          {produtos.map((produto) => {
            const foto = fotosProdutos[produto.id];
            const cor = corProduto[produto.id] ?? 'papel';
            return (
              <li class={`v8-produto v8-produto--${cor}`}>
                {foto && (
                  <div class="v8-produto-foto">
                    <Image
                      src={foto.src}
                      alt={foto.alt}
                      widths={[320, 480, 680]}
                      sizes="(min-width: 1024px) 340px, (min-width: 640px) 46vw, 88vw"
                    />
                  </div>
                )}
                <span class="v8-produto-chip">{produto.subtitulo}</span>
                <h3>{produto.nome}</h3>
                <p class="v8-produto-desc">{produto.descricao}</p>
                <ul class="v8-tags" role="list">
                  {produto.destaques.map((destaque) => (
                    <li class="v8-tag">{destaque}</li>
                  ))}
                </ul>
              </li>
            );
          })}
        </ul>
      </div>
    </section>

    <!-- ═══ COMO FUNCIONA ═══ -->
    <section id="como-funciona" class="v8-secao v8-secao--branco" aria-labelledby="titulo-como">
      <div class="v8-caixa">
        <p class="v8-kicker">Comodato em 6 etapas</p>
        <h2 class="v8-titulo" id="titulo-como">Do diagnóstico à recarga contínua</h2>
        <p class="v8-sub">
          Sem investimento inicial em equipamento: a Allcanci instala, treina e acompanha —
          sua equipe só usa.
        </p>

        <ol class="v8-cartas" role="list">
          {etapasComodato.map((etapa, i) => (
            <li class="v8-carta">
              <span class="v8-carta-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <h3>{etapa.titulo}</h3>
              <p>{etapa.texto}</p>
            </li>
          ))}
        </ol>

        <div class="v8-colagem">
          <figure class="v8-palco v8-palco--recarga">
            <Image
              src={img.comoUsar}
              alt="Ilustração da recarga em três passos: primeiro, insira o pincel no encaixe da máquina e a tampa na trava de segurança; depois, aguarde 22 segundos para a recarga; por fim, retire o pincel e a tampa e utilize normalmente."
              widths={[420, 640, 900]}
              sizes="(min-width: 1024px) 34rem, 88vw"
            />
            <figcaption class="v8-adesivo v8-adesivo--legenda">A recarga em 3 passos</figcaption>
          </figure>
          <figure class="v8-recorte">
            <Image
              src={topo3d}
              alt="Vista superior da máquina FILL Ink Injector mostrando os encaixes de recarga nas cores azul, preto e vermelho"
              widths={[320, 480, 640]}
              sizes="(min-width: 1024px) 20rem, 60vw"
            />
            <figcaption class="v8-adesivo v8-adesivo--rosa">vista de cima: azul · preto · vermelho</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ═══ SIMULADOR ═══ -->
    <section id="simulador" class="v8-secao v8-secao--violeta" aria-labelledby="titulo-simulador">
      <div class="v8-caixa">
        <p class="v8-kicker v8-kicker--hero">Simulador de economia</p>
        <h2 class="v8-titulo" id="titulo-simulador">Quanto a sua instituição economiza?</h2>
        <p class="v8-sub">
          Arraste o controle do placar e veja a projeção anual em tempo real — recargas,
          custos e plástico que deixa de virar lixo.
        </p>

        <div class="v8-placar">
          <div class="v8-placar-topo">
            <span class="v8-placar-luz" aria-hidden="true"></span>
            <p class="v8-placar-titulo">Placar · economia anual</p>
            <span class="v8-placar-luz" aria-hidden="true"></span>
          </div>
          <div class="v8-placar-corpo">
            <div class="v8-controles">
              <label class="v8-controles-label" for="sim-professores">
                Professores na instituição
              </label>
              <div class="v8-controles-linha">
                <input
                  type="range"
                  id="sim-professores"
                  min="1"
                  max="200"
                  step="1"
                  value={professoresIniciais}
                />
                <input
                  type="number"
                  id="sim-professores-num"
                  min="1"
                  max="999"
                  value={professoresIniciais}
                  aria-label="Número de professores"
                />
              </div>
              <p class="v8-premissas">
                Premissas do cálculo: {PREMISSAS.recargasPorProfessorAno} recargas por
                professor/ano · crédito de recarga a {reais(PREMISSAS.precoCreditoReais)} · 1
                recarga rende ~{PREMISSAS.kmPorRecarga} km de escrita · pincel descartável rende
                ~{PREMISSAS.metrosPorDescartavel} m e custa {reais(PREMISSAS.precoDescartavelReais)} ·
                ~{PREMISSAS.kgPlasticoPorDescartavel * 1000} g de plástico por descartável.
              </p>
            </div>

            <dl class="v8-leituras">
              <div class="v8-leitura">
                <dt>Recargas por ano</dt>
                <dd id="sim-recargas">{sim0.recargasAno.toLocaleString('pt-BR')}</dd>
              </div>
              <div class="v8-leitura">
                <dt>Investimento FILL/ano</dt>
                <dd id="sim-custo-fill">{reais(sim0.custoFill)}</dd>
              </div>
              <div class="v8-leitura">
                <dt>Descartáveis evitados</dt>
                <dd id="sim-descartaveis">{sim0.descartaveis.toLocaleString('pt-BR')}</dd>
              </div>
              <div class="v8-leitura">
                <dt>Plástico evitado</dt>
                <dd id="sim-plastico">{sim0.plasticoEvitadoKg.toLocaleString('pt-BR')} kg</dd>
              </div>
              <div class="v8-leitura v8-leitura--destaque">
                <dt>Economia estimada/ano</dt>
                <dd id="sim-economia">{reais(sim0.economia)}</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PROVA SOCIAL ═══ -->
    <section id="prova-social" class="v8-secao v8-secao--papel" aria-labelledby="titulo-prova">
      <div class="v8-caixa">
        <p class="v8-kicker">Confiança</p>
        <h2 class="v8-titulo" id="titulo-prova">{provaSocial.titulo}</h2>
        <p class="v8-sub">{provaSocial.texto}</p>

        <ul class="v8-bottons" role="list">
          {provaSocial.selos.map((selo, i) => (
            <li class={`v8-botton v8-botton--${corSelo[i % corSelo.length]}`}>
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="m4.5 10.5 3.4 3.4 7.6-8" stroke="currentColor" stroke-width="2.6" stroke-linecap="square" />
              </svg>
              {selo}
            </li>
          ))}
        </ul>

        {provaSocial.depoimentos.length > 0 && (
          <ul class="v8-depoimentos" role="list">
            {provaSocial.depoimentos.map((dep) => (
              <li>
                <blockquote>
                  <p>{dep.citacao}</p>
                  <footer>
                    {dep.autor} — {dep.instituicao}
                  </footer>
                </blockquote>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

    <!-- ═══ SUSTENTABILIDADE ═══ -->
    <section id="sustentabilidade" class="v8-secao v8-secao--preto" aria-labelledby="titulo-sustentabilidade">
      <div class="v8-caixa">
        <p class="v8-kicker v8-kicker--acido">Sustentabilidade</p>
        <h2 class="v8-titulo" id="titulo-sustentabilidade">{sustentabilidade.titulo}</h2>
        <p class="v8-sub">{sustentabilidade.texto}</p>

        <ul class="v8-verde-grade" role="list">
          {sustentabilidade.pontos.map((ponto) => (
            <li class="v8-verde-card">
              <h3>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 19C5 10 10 5 19 5c0 9-5 14-14 14Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
                  <path d="M5 19c3-5.5 6.5-9 10-10.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                {ponto.titulo}
              </h3>
              <p>{ponto.texto}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ═══ FAQ ═══ -->
    <section id="faq" class="v8-secao v8-secao--branco" aria-labelledby="titulo-faq">
      <div class="v8-caixa">
        <p class="v8-kicker">FAQ</p>
        <h2 class="v8-titulo" id="titulo-faq">Perguntas frequentes</h2>
        <p class="v8-sub">
          O que escolas e instituições mais perguntam antes de adotar o ecossistema FILL.
        </p>

        <div class="v8-faq-pilha">
          {faq.map((item, i) => (
            <details class={`v8-faq-item v8-faq-item--${corFaq[i % corFaq.length]}`}>
              <summary>
                {item.pergunta}
                <span class="v8-faq-mais" aria-hidden="true">+</span>
              </summary>
              <p class="v8-faq-resposta">{item.resposta}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ CONTATO ═══ -->
    <section id="contato" class="v8-secao v8-secao--acido" aria-labelledby="titulo-contato">
      <div class="v8-caixa v8-cartaz">
        <p class="v8-kicker v8-kicker--preto">Bora aposentar o descartável?</p>
        <h2 id="titulo-contato" class="v8-cartaz-titulo">
          Leve o quiosque FILL para a sua instituição
        </h2>
        <p class="v8-cartaz-texto">
          Fale com a equipe da {empresa.nome} e receba uma proposta de comodato sob medida —
          entrega em até {numeros.entregaDiasUteis} dias úteis para todo o Brasil.
        </p>

        <div class="v8-cartaz-cta">
          <a
            class="v8-botao v8-botao--preto v8-botao--gigante"
            href={contatos.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
            </svg>
            Chamar no WhatsApp
          </a>
        </div>

        <ul class="v8-cartaz-lista" role="list">
          <li>
            <a class="v8-chip" href={`mailto:${contatos.email}`}>{contatos.email}</a>
          </li>
          <li>
            <a class="v8-chip" href={telefoneHref}>{contatos.telefone}</a>
          </li>
        </ul>

        <address class="v8-cartaz-endereco">{contatos.endereco}</address>

        <ul class="v8-cartaz-redes" role="list">
          {redes.map((rede) => (
            <li>
              <a class="v8-chip" href={rede.url} target="_blank" rel="noopener noreferrer">
                {rede.nome}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <footer class="v8-rodape">
    <div class="v8-caixa">
      <div class="v8-rodape-grade">
        <div>
          <p class="v8-rodape-marca">allcanci<span>&nbsp;tecnologia</span></p>
          <p class="v8-rodape-slogan">{empresa.slogan}. {empresa.descricao}</p>
        </div>
        <div>
          <h2>Contato</h2>
          <ul role="list">
            <li><a href={`mailto:${contatos.email}`}>{contatos.email}</a></li>
            <li>
              <a href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">
                WhatsApp — {contatos.telefone}
              </a>
            </li>
            <li>{contatos.endereco}</li>
          </ul>
        </div>
        <div>
          <h2>Redes</h2>
          <ul role="list">
            {redes.map((rede) => (
              <li>
                <a href={rede.url} target="_blank" rel="noopener noreferrer">{rede.nome}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <div class="v8-rodape-nota">
        <p>© {ano} {empresa.nome} — {empresa.cidade}</p>
        <p><a href={`${base}/`}>Ver as 10 propostas de design</a></p>
      </div>
    </div>
  </footer>

  <script src="../../scripts/v8.js"></script>
</Layout>
