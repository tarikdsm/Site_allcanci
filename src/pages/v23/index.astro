---
import Layout from '../../layouts/Layout.astro';
import ExperienceBody from '../../components/ExperienceBody.astro';
import { Image, getImage } from 'astro:assets';
import { empresa, numeros, contatos } from '../../data/site';
import * as img from '../../data/imagens';
import maquinaRender from '../../assets/3d/maquina-fill-render.png';
import '@fontsource-variable/fraunces/full.css';
import '@fontsource-variable/fraunces/full-italic.css';
import '../../styles/v23.css';

const base = import.meta.env.BASE_URL;
const ogImage = await getImage({ src: img.ecoMarkerTrioTampas, format: 'webp', width: 1200 });
const copy = {
  produtosKicker: 'Um ecossistema que floresce',
  produtosTitulo: 'Cada peça do jardim tem sua função',
  produtosTexto: 'Máquina, pincel, tinta, apagador, refil e aplicativo formam um organismo vivo: nada se perde, tudo se renova.',
  processoKicker: 'O cultivo da adoção',
  processoTitulo: 'Do plantio à colheita, com a Allcanci ao lado',
  processoTexto: 'A Allcanci dimensiona, instala, treina e acompanha. Sua escola só precisa colher os frutos.',
  simuladorKicker: 'Meça a regeneração',
  simuladorTitulo: 'Quanto sua escola deixa de arrancar da terra?',
  simuladorTexto: 'Ajuste o número de professores e veja brotar a projeção anual: menos plástico, menos descarte, mais economia.',
  provaKicker: 'Um jardim que já deu frutos',
  sustentabilidadeKicker: 'Regeneração por desenho',
  faqTexto: 'Tudo o que sua instituição precisa saber para trocar o descarte pela regeneração.',
  contatoTitulo: 'Plante o FILL na sua escola',
  contatoTexto: `Converse com a ${empresa.nome} e receba uma proposta dimensionada para a sua instituição florescer.`,
};
---

<Layout
  title="Allcanci Jardim Vivo — Recarregar é regenerar"
  description="O ecossistema FILL como um jardim vivo: a tinta é a seiva, a máquina é o tronco e cada recarga, uma nova brotação. Nada é descartável."
  ogImage={ogImage.src}
  bodyClass="v23"
>
  <a class="v23-skip" href="#hero">Pular para o conteúdo</a>
  <canvas class="v23-pollen" aria-hidden="true"></canvas>

  <aside class="v23-vine" aria-hidden="true">
    <svg viewBox="0 0 140 1000" preserveAspectRatio="xMidYMid meet">
      <path class="v23-vine-branch" data-vine-grow pathLength="100" d="M72 690 C 100 660 118 642 130 606" />
      <path class="v23-vine-branch" data-vine-grow pathLength="100" d="M70 382 C 42 352 26 330 14 296" />
      <path class="v23-vine-stem" data-vine-grow pathLength="100" d="M70 1010 C 12 890 128 800 72 690 C 18 582 122 492 70 382 C 22 282 118 178 68 78 C 60 45 64 15 70 -8" />
      <g transform="translate(46,868) rotate(-40)"><path class="v23-leaf" data-leaf-at="0.14" d="M0 0 C 16 -18 40 -18 52 0 C 40 16 16 16 0 0 Z" /></g>
      <g transform="translate(102,782) rotate(150)"><path class="v23-leaf" data-leaf-at="0.24" d="M0 0 C 16 -18 40 -18 52 0 C 40 16 16 16 0 0 Z" /></g>
      <g transform="translate(130,606) rotate(-25)"><path class="v23-leaf" data-leaf-at="0.40" d="M0 0 C 13 -15 33 -15 43 0 C 33 13 13 13 0 0 Z" /></g>
      <g transform="translate(44,640) rotate(-35)"><path class="v23-leaf" data-leaf-at="0.37" d="M0 0 C 16 -18 40 -18 52 0 C 40 16 16 16 0 0 Z" /></g>
      <g transform="translate(104,520) rotate(150)"><path class="v23-leaf" data-leaf-at="0.50" d="M0 0 C 16 -18 40 -18 52 0 C 40 16 16 16 0 0 Z" /></g>
      <g transform="translate(42,330) rotate(-40)"><path class="v23-leaf" data-leaf-at="0.68" d="M0 0 C 16 -18 40 -18 52 0 C 40 16 16 16 0 0 Z" /></g>
      <g transform="translate(14,296) rotate(195)"><path class="v23-leaf" data-leaf-at="0.74" d="M0 0 C 13 -15 33 -15 43 0 C 33 13 13 13 0 0 Z" /></g>
      <g transform="translate(100,200) rotate(155)"><path class="v23-leaf" data-leaf-at="0.80" d="M0 0 C 16 -18 40 -18 52 0 C 40 16 16 16 0 0 Z" /></g>
      <g transform="translate(70,42)">
        <g class="v23-flower" data-leaf-at="0.92">
          <circle cx="0" cy="-15" r="11" /><circle cx="14.3" cy="-4.6" r="11" /><circle cx="8.8" cy="12.1" r="11" />
          <circle cx="-8.8" cy="12.1" r="11" /><circle cx="-14.3" cy="-4.6" r="11" />
          <circle class="v23-flower-heart" cx="0" cy="0" r="7.5" />
        </g>
      </g>
    </svg>
  </aside>

  <header class="v23-topbar">
    <a class="v23-brand" href={`${base}/`} aria-label="Allcanci — voltar às propostas">allcanci<span>jardim vivo</span></a>
    <nav aria-label="Navegação principal">
      <a href="#produtos">Jardim</a><a href="#como-funciona">Cultivo</a><a href="#simulador">Colheita</a><a href="#contato">Contato</a>
    </nav>
    <a class="v23-mini-cta" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Plantar ↗</a>
  </header>

  <main>
    <section id="hero" class="v23-hero" aria-labelledby="v23-hero-title" data-experience-section>
      <span class="v23-float-leaf v23-float-leaf-a" aria-hidden="true"></span>
      <span class="v23-float-leaf v23-float-leaf-b" aria-hidden="true"></span>
      <div class="v23-shell v23-hero-grid">
        <div class="v23-hero-copy">
          <p class="v23-eyebrow">Sustentabilidade como natureza</p>
          <h1 id="v23-hero-title">Recarregar é <em>regenerar</em>.</h1>
          <p class="v23-lead">O ecossistema FILL trata o pincel de quadro branco como parte de um jardim: a tinta é a seiva, a máquina é o tronco e cada recarga, uma nova brotação. Nada é descartável — tudo regenera.</p>
          <div class="v23-actions">
            <a class="v23-button v23-button-primary" href="#produtos">Explorar o jardim <span aria-hidden="true">↓</span></a>
            <a class="v23-button" href="#simulador">Ver a colheita</a>
          </div>
          <ul class="v23-hero-stats" role="list">
            <li><strong>{numeros.recargaSegundos}s</strong><span>por recarga</span></li>
            <li><strong>{numeros.escolas}</strong><span>escolas no jardim</span></li>
            <li><strong>{numeros.escritaKm} km</strong><span>de escrita por carga</span></li>
          </ul>
        </div>

        <div class="v23-hero-visual">
          <svg class="v23-stem" viewBox="0 0 420 560" aria-hidden="true">
            <path class="v23-stem-glow" d="M210 556 C 96 470 330 386 212 292 C 100 202 316 120 210 16" fill="none" />
            <path id="v23-sap-path" class="v23-stem-path" d="M210 556 C 96 470 330 386 212 292 C 100 202 316 120 210 16" fill="none" />
            <circle class="v23-sap-drop" cx="210" cy="556" r="10" />
          </svg>
          <div class="v23-bloom-photo">
            <Image src={maquinaRender} alt="Máquina FILL Ink Injector em render 3D, brotando como fruto de um caule" widths={[320, 480, 640]} sizes="(min-width: 900px) 32vw, 72vw" loading="eager" />
          </div>
          <span class="v23-petal v23-petal-a" aria-hidden="true"></span>
          <span class="v23-petal v23-petal-b" aria-hidden="true"></span>
        </div>
      </div>
      <div class="v23-divider" aria-hidden="true">
        <svg viewBox="0 0 1440 110" preserveAspectRatio="none"><path d="M0 70 C 180 20 360 105 600 60 C 840 15 1040 100 1240 55 C 1330 36 1400 45 1440 60 L1440 110 L0 110 Z" /></svg>
      </div>
    </section>

    <ExperienceBody prefix="v23" copy={copy} />
  </main>
  <script src="../../scripts/v23.js"></script>
</Layout>
