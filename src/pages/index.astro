---
import type { ImageMetadata } from 'astro';
import Layout from '../layouts/Layout.astro';
import { Image, getImage } from 'astro:assets';
import { empresa, numeros, contatos, redes } from '../data/site';
import { produtos } from '../data/produtos';
import { etapasComodato } from '../data/comodato';
import { faq } from '../data/faq';
import { provaSocial } from '../data/provaSocial';
import { sustentabilidade } from '../data/sustentabilidade';
import * as img from '../data/imagens';
import { simular, reais, PREMISSAS } from '../scripts/simulador-core.js';
import '../styles/site.css';

const ano = new Date().getFullYear();

const ogImage = await getImage({ src: img.ecoMarkerTrio, format: 'webp', width: 1200 });

// Estado inicial do simulador (renderizado no servidor para funcionar sem JS)
const professoresIniciais = 20;
const sim0 = simular(professoresIniciais);

// Post-its do hero — números vindos de src/data/site.ts
const postits = [
  { numero: numeros.escolas, rotulo: 'escolas já atendidas no Brasil' },
  { numero: `${numeros.recargaSegundos}s`, rotulo: 'por recarga automática' },
  { numero: `${numeros.escritaKm} km`, rotulo: 'de escrita por recarga' },
];

// Tintas do quadro — os círculos numerados da trilha alternam entre elas
const tintas = ['var(--azul)', 'var(--vermelho)', 'var(--preto)'];

// Variações do traço ondulado sob os títulos (mesma família de rabisco)
const tracoA = 'M4 10 C 60 2, 120 14, 180 8 S 280 4, 316 9';
const tracoB = 'M4 9 C 44 13, 92 3, 152 9 C 212 15, 262 4, 316 8';

// Fotos dos produtos — página clara: todas as fotos são seguras aqui
const fotosProdutos: Record<string, { src: ImageMetadata; alt: string }> = {
  'ink-injector': {
    src: img.inkInjector,
    alt: 'Máquina FILL Ink Injector vista de frente, com encaixes de recarga nas cores azul, preto e vermelho e visor digital aceso',
  },
  'eco-marker': {
    src: img.ecoMarkerTrio,
    alt: 'Três pincéis recarregáveis FILL Eco Marker nas cores vermelho, preto e azul',
  },
  'master-color': {
    src: img.masterColorTrio,
    alt: 'Três frascos de 500 ml de tinta FILL Master Color nas cores azul, vermelho e preto',
  },
  'master-clean': {
    src: img.masterClean,
    alt: 'Estojo apagador FILL Master Clean 3P na cor azul, com feltro apagador na base',
  },
  refil: {
    src: img.ecoMarkerPreto,
    alt: 'Pincel FILL Eco Marker preto com refil de feltro removível translúcido encaixado na base',
  },
  app: {
    src: img.moedasCredito,
    alt: 'Três moedas azuis de crédito de recarga FILL com gota de tinta em relevo',
  },
};

const linksMenu = [
  { href: '#produtos', rotulo: 'Produtos' },
  { href: '#como-funciona', rotulo: 'Como funciona' },
  { href: '#simulador', rotulo: 'Simulador' },
  { href: '#sustentabilidade', rotulo: 'Sustentabilidade' },
  { href: '#faq', rotulo: 'FAQ' },
  { href: '#contato', rotulo: 'Contato' },
];

const telefoneHref = `tel:+55${contatos.telefone.replace(/\D/g, '')}`;
---

<Layout
  title="Allcanci Tecnologia — Nenhum professor merece pincel seco"
  description="Chega de pincel seco em sala de aula: pincéis FILL da Allcanci escrevem cerca de 1 km por recarga, em comodato para escolas de todo o Brasil."
  ogImage={ogImage.src}
  bodyClass="site"
>
  <a class="site-skip" href="#hero">Pular para o conteúdo</a>

  <header class="site-topo">
    <div class="site-caixa site-topo-linha">
      <a class="site-marca" href="#hero">
        <span class="site-tampas" aria-hidden="true"><i></i><i></i><i></i></span>
        allcanci<span>&nbsp;tecnologia</span>
      </a>
      <nav class="site-nav" aria-label="Seções da página">
        <ul class="site-menu" role="list">
          {linksMenu.map((item) => (
            <li><a href={item.href}>{item.rotulo}</a></li>
          ))}
        </ul>
      </nav>
      <a
        class="site-botao site-botao--verde site-botao--mini"
        href={contatos.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
        </svg>
        WhatsApp
      </a>
    </div>
  </header>

  <main>
    <!-- ═══ HERO ═══ -->
    <section id="hero" class="site-hero" aria-labelledby="titulo-hero">
      <div class="site-caixa">
        <div class="site-hero-grade">
          <div>
            <p class="site-etiqueta">{empresa.nome} · {empresa.cidade}</p>
            <h1 id="titulo-hero">
              Nenhum professor merece
              <span class="site-circulado">
                pincel seco
                <svg class="traco" viewBox="0 0 300 110" preserveAspectRatio="none" aria-hidden="true">
                  <path
                    d="M158 8 C 236 6, 292 26, 292 55 C 292 86, 226 104, 152 103 C 74 102, 10 86, 9 54 C 8 24, 78 7, 190 12"
                    fill="none"
                    stroke="var(--vermelho)"
                    stroke-width="7"
                    stroke-linecap="round"
                  />
                </svg>
              </span>.
            </h1>
            <p class="site-hero-sub">{empresa.descricao}</p>
            <div class="site-hero-ctas">
              <a
                class="site-botao site-botao--azul"
                href={contatos.whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                </svg>
                Falar no WhatsApp
              </a>
              <a class="site-botao site-botao--contorno" href="#simulador">Fazer a conta no quadro</a>
            </div>
          </div>

          <figure class="site-quadro-foto site-fita">
            <Image
              src={img.ecoMarkerTrio}
              alt="Três pincéis recarregáveis FILL Eco Marker nas cores vermelho, preto e azul"
              widths={[420, 640, 900, 1240]}
              sizes="(min-width: 960px) 34rem, 88vw"
              loading="eager"
            />
            <figcaption>FILL Eco Marker — recarrega em {numeros.recargaSegundos}s, dura anos</figcaption>
          </figure>
        </div>

        <svg class="traco site-hero-doodle" viewBox="0 0 150 100" aria-hidden="true">
          <path d="M10 14 C 56 6, 104 28, 128 70" fill="none" stroke="var(--vermelho)" stroke-width="5" stroke-linecap="round" />
          <path d="M106 64 L130 72 L124 46" fill="none" stroke="var(--vermelho)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>

        <ul class="site-postits" role="list">
          {postits.map((p) => (
            <li class="site-postit site-fita">
              <strong>{p.numero}</strong>
              <span>{p.rotulo}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ═══ PRODUTOS ═══ -->
    <section id="produtos" class="site-secao" aria-labelledby="titulo-produtos">
      <div class="site-caixa">
        <header class="site-cabeca">
          <p class="site-kicker">Ecossistema FILL</p>
          <h2 class="site-titulo" id="titulo-produtos">O material da lição de hoje</h2>
          <svg class="traco site-traco-titulo" viewBox="0 0 320 14" preserveAspectRatio="none" aria-hidden="true">
            <path d={tracoA} fill="none" stroke="var(--azul)" stroke-width="6" stroke-linecap="round" />
          </svg>
          <p class="site-sub">
            Seis itens que trabalham juntos para aposentar o pincel descartável — da máquina
            de recarga ao aplicativo de gestão.
          </p>
        </header>

        <ul class="site-produtos-grade" role="list">
          {produtos.map((produto) => {
            const foto = fotosProdutos[produto.id];
            return (
              <li class="site-produto">
                {foto && (
                  <div class="site-produto-foto">
                    <Image
                      src={foto.src}
                      alt={foto.alt}
                      widths={[320, 480, 680]}
                      sizes="(min-width: 1000px) 340px, (min-width: 640px) 46vw, 88vw"
                    />
                  </div>
                )}
                <div class="site-produto-corpo">
                  <span class="site-produto-tag">{produto.subtitulo}</span>
                  <h3>{produto.nome}</h3>
                  <p class="site-produto-desc">{produto.descricao}</p>
                  <ul class="site-checklist" role="list">
                    {produto.destaques.map((destaque) => (
                      <li>{destaque}</li>
                    ))}
                  </ul>
                </div>
              </li>
            );
          })}
        </ul>
      </div>
    </section>

    <!-- ═══ COMO FUNCIONA ═══ -->
    <section id="como-funciona" class="site-secao" aria-labelledby="titulo-como">
      <div class="site-caixa">
        <header class="site-cabeca">
          <p class="site-kicker">Comodato em 6 etapas</p>
          <h2 class="site-titulo" id="titulo-como">O passo a passo, desenhado no quadro</h2>
          <svg class="traco site-traco-titulo" viewBox="0 0 320 14" preserveAspectRatio="none" aria-hidden="true">
            <path d={tracoB} fill="none" stroke="var(--vermelho)" stroke-width="6" stroke-linecap="round" />
          </svg>
          <p class="site-sub">
            Sem investimento inicial em equipamento: a Allcanci instala, treina e acompanha —
            a sua equipe só usa. Siga a trilha.
          </p>
        </header>

        <ol class="site-trilha" role="list">
          {etapasComodato.map((etapa, i) => (
            <li class="site-etapa">
              <div class="site-etapa-cartao">
                <span class="site-etapa-num" aria-hidden="true">
                  <svg viewBox="0 0 44 44" aria-hidden="true">
                    <path
                      d="M22 3.5 C 33 3.5 40.5 10.5 40.5 21.5 C 40.5 33 33 40.5 21.5 40.5 C 10.5 40.5 3.5 33 3.5 21.5 C 3.5 11 11 3.5 25 4.5"
                      fill="none"
                      stroke={tintas[i % 3]}
                      stroke-width="3.2"
                      stroke-linecap="round"
                    />
                  </svg>
                  {i + 1}
                </span>
                <div>
                  <h3>{etapa.titulo}</h3>
                  <p>{etapa.texto}</p>
                </div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ═══ SIMULADOR ═══ -->
    <section id="simulador" class="site-secao" aria-labelledby="titulo-simulador">
      <div class="site-caixa">
        <header class="site-cabeca">
          <p class="site-kicker">Simulador de economia</p>
          <h2 class="site-titulo" id="titulo-simulador">Vamos fazer a continha no quadro?</h2>
          <svg class="traco site-traco-titulo" viewBox="0 0 320 14" preserveAspectRatio="none" aria-hidden="true">
            <path d={tracoA} fill="none" stroke="var(--azul)" stroke-width="6" stroke-linecap="round" />
          </svg>
          <p class="site-sub">
            Diga quantos professores a sua instituição tem e a gente arma a conta do ano —
            descartáveis de um lado, FILL do outro.
          </p>
        </header>

        <div class="site-conta">
          <div>
            <label class="site-conta-label" for="sim-professores">
              Quantos professores na sua escola?
            </label>
            <div class="site-conta-controles">
              <input
                type="range"
                id="sim-professores"
                min="1"
                max="200"
                step="1"
                value={professoresIniciais}
              />
              <input
                type="number"
                id="sim-professores-num"
                min="1"
                max="999"
                value={professoresIniciais}
                aria-label="Número de professores"
              />
            </div>
            <p class="site-premissas">
              Premissas do cálculo: {PREMISSAS.recargasPorProfessorAno} recargas por
              professor/ano · crédito de recarga a {reais(PREMISSAS.precoCreditoReais)} · 1
              recarga rende ~{PREMISSAS.kmPorRecarga} km de escrita · pincel descartável rende
              ~{PREMISSAS.metrosPorDescartavel} m e custa {reais(PREMISSAS.precoDescartavelReais)} ·
              ~{PREMISSAS.kgPlasticoPorDescartavel * 1000} g de plástico por descartável.
            </p>
          </div>

          <div class="site-conta-quadro">
            <p class="site-conta-linha">
              <span class="site-conta-rotulo">No modelo descartável</span>
              <strong id="sim-descartaveis">{sim0.descartaveis.toLocaleString('pt-BR')}</strong>{' '}pincéis
              <span class="site-op" aria-hidden="true">×</span><span class="visually-hidden">vezes</span>
              {reais(PREMISSAS.precoDescartavelReais)}
              <span class="site-op" aria-hidden="true">=</span><span class="visually-hidden">igual a</span>
              <strong id="site-custo-descartaveis" class="site-custo-ruim">{reais(sim0.custoDescartaveis)}</strong>
            </p>
            <p class="site-conta-linha">
              <span class="site-conta-rotulo">Com o ecossistema FILL</span>
              <strong id="sim-recargas">{sim0.recargasAno.toLocaleString('pt-BR')}</strong>{' '}recargas
              <span class="site-op" aria-hidden="true">×</span><span class="visually-hidden">vezes</span>
              {reais(PREMISSAS.precoCreditoReais)}
              <span class="site-op" aria-hidden="true">=</span><span class="visually-hidden">igual a</span>
              <strong class="site-custo-bom" id="sim-custo-fill">{reais(sim0.custoFill)}</strong>
            </p>
            <p class="site-conta-linha site-conta-economia">
              <span class="site-conta-rotulo">Economia estimada por ano</span>
              <span class="site-sublinhado">
                <strong id="sim-economia">{reais(sim0.economia)}</strong>
                <svg class="traco" viewBox="0 0 300 26" preserveAspectRatio="none" aria-hidden="true">
                  <path d="M6 8 C 80 2, 200 12, 294 6" fill="none" stroke="var(--verde)" stroke-width="6" stroke-linecap="round" />
                  <path d="M20 20 C 110 14, 210 24, 284 18" fill="none" stroke="var(--verde)" stroke-width="6" stroke-linecap="round" />
                </svg>
              </span>
            </p>
            <p class="site-conta-linha site-conta-bonus">
              <svg class="site-folha" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M5 19 C 5 10, 10 5, 19 5 C 19 14, 14 19, 5 19 Z" stroke="var(--verde)" stroke-width="2.2" stroke-linejoin="round" />
                <path d="M5 19 C 8 13.5, 11.5 9.8, 15 8" stroke="var(--verde)" stroke-width="2.2" stroke-linecap="round" />
              </svg>
              <span>
                E de lição de casa: <strong id="sim-plastico">{sim0.plasticoEvitadoKg.toLocaleString('pt-BR')} kg</strong>{' '}de
                plástico que não viram lixo.
              </span>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PROVA SOCIAL ═══ -->
    <section id="prova-social" class="site-secao" aria-labelledby="titulo-prova">
      <div class="site-caixa">
        <div class="site-prova-grade">
          <header class="site-cabeca">
            <p class="site-kicker">Confiança</p>
            <h2 class="site-titulo" id="titulo-prova">{provaSocial.titulo}</h2>
            <svg class="traco site-traco-titulo" viewBox="0 0 320 14" preserveAspectRatio="none" aria-hidden="true">
              <path d={tracoB} fill="none" stroke="var(--vermelho)" stroke-width="6" stroke-linecap="round" />
            </svg>
            <p class="site-sub">{provaSocial.texto}</p>
          </header>

          <p class="site-carimbo">
            Tecnologia patenteada
            <small>única fabricante no mundo</small>
          </p>
        </div>

        <ul class="site-selos" role="list">
          {provaSocial.selos.map((selo) => (
            <li class="site-selo">{selo}</li>
          ))}
        </ul>

        {provaSocial.depoimentos.length > 0 && (
          <ul role="list">
            {provaSocial.depoimentos.map((dep) => (
              <li>
                <blockquote>
                  <p>{dep.citacao}</p>
                  <footer>{dep.autor} — {dep.instituicao}</footer>
                </blockquote>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

    <!-- ═══ SUSTENTABILIDADE ═══ -->
    <section id="sustentabilidade" class="site-secao" aria-labelledby="titulo-sustentabilidade">
      <div class="site-caixa">
        <header class="site-cabeca">
          <p class="site-kicker">Sustentabilidade</p>
          <h2 class="site-titulo" id="titulo-sustentabilidade">{sustentabilidade.titulo}</h2>
          <svg class="traco site-traco-titulo" viewBox="0 0 320 14" preserveAspectRatio="none" aria-hidden="true">
            <path d={tracoA} fill="none" stroke="var(--verde)" stroke-width="6" stroke-linecap="round" />
          </svg>
          <p class="site-sub">{sustentabilidade.texto}</p>
        </header>

        <ul class="site-eco-grade" role="list">
          {sustentabilidade.pontos.map((ponto) => (
            <li class="site-eco-postit site-fita">
              <h3>{ponto.titulo}</h3>
              <p>{ponto.texto}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ═══ FAQ ═══ -->
    <section id="faq" class="site-secao" aria-labelledby="titulo-faq">
      <div class="site-caixa">
        <header class="site-cabeca">
          <p class="site-kicker">FAQ</p>
          <h2 class="site-titulo" id="titulo-faq">O caderno de dúvidas</h2>
          <svg class="traco site-traco-titulo" viewBox="0 0 320 14" preserveAspectRatio="none" aria-hidden="true">
            <path d={tracoB} fill="none" stroke="var(--preto)" stroke-width="6" stroke-linecap="round" />
          </svg>
          <p class="site-sub">
            As perguntas que toda escola faz antes de aposentar o pincel descartável.
          </p>
        </header>

        <div class="site-caderno">
          {faq.map((item) => (
            <details>
              <summary>
                <svg class="site-faq-seta" viewBox="0 0 20 12" fill="none" aria-hidden="true">
                  <path d="M2 2.2 C 5.5 6.5, 8.5 9.3, 10 10 C 11.5 8.6, 15 5, 18 2.4" stroke="var(--azul)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {item.pergunta}
              </summary>
              <p class="site-faq-resposta">{item.resposta}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ CONTATO ═══ -->
    <section id="contato" class="site-secao" aria-labelledby="titulo-contato">
      <div class="site-caixa">
        <div class="site-contato-card">
          <svg class="traco site-moldura" viewBox="0 0 1000 560" preserveAspectRatio="none" aria-hidden="true">
            <path
              d="M96 22 C 300 12, 640 14, 916 24 C 962 26, 984 52, 982 108 C 988 240, 986 372, 978 470 C 976 516, 946 536, 886 534 C 650 544, 330 542, 108 532 C 56 530, 26 508, 26 452 C 16 340, 18 196, 26 96 C 30 48, 52 26, 150 22"
              fill="none"
              stroke="var(--azul)"
              stroke-width="7"
              stroke-linecap="round"
            />
          </svg>

          <h2 id="titulo-contato">Vamos tirar o pincel seco da sua escola?</h2>
          <p>
            Fale com a equipe da {empresa.nome} e receba uma proposta de comodato sob medida —
            entrega em até {numeros.entregaDiasUteis} dias úteis para todo o Brasil.
          </p>

          <div class="site-contato-cta">
            <a
              class="site-botao site-botao--verde"
              href={contatos.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
              </svg>
              Chamar no WhatsApp
            </a>
          </div>

          <ul class="site-contato-lista" role="list">
            <li><a class="site-chip" href={`mailto:${contatos.email}`}>{contatos.email}</a></li>
            <li><a class="site-chip" href={telefoneHref}>{contatos.telefone}</a></li>
          </ul>

          <address>{contatos.endereco}</address>

          <ul class="site-redes" role="list">
            {redes.map((rede) => (
              <li>
                <a class="site-chip" href={rede.url} target="_blank" rel="noopener noreferrer">
                  {rede.nome === 'Instagram' && (
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M7.2 3.8 C 11 3.4, 15.6 3.5, 18.2 4.1 C 19.8 4.5, 20.4 5.8, 20.4 8.4 C 20.6 12, 20.5 15.8, 20 17.9 C 19.6 19.5, 18.3 20.2, 15.6 20.2 C 12 20.5, 8.2 20.4, 6.2 19.8 C 4.6 19.4, 3.8 18.2, 3.8 15.6 C 3.6 12, 3.6 8, 4.2 6 C 4.6 4.6, 5.4 4, 7.6 3.9" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" />
                      <path d="M12 8.6 C 14.1 8.6, 15.5 10, 15.5 12 C 15.5 14.1, 14 15.5, 12 15.5 C 9.9 15.5, 8.5 14, 8.5 12 C 8.5 10, 10 8.5, 12.4 8.7" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" />
                      <circle cx="16.9" cy="7" r="1.2" fill="currentColor" />
                    </svg>
                  )}
                  {rede.nome === 'LinkedIn' && (
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path d="M6.4 3.9 C 10 3.5, 15.5 3.5, 18.3 4.2 C 19.9 4.6, 20.4 5.8, 20.4 8.4 C 20.6 12, 20.5 15.9, 20 17.9 C 19.6 19.5, 18.2 20.2, 15.5 20.2 C 12 20.5, 8 20.4, 6.1 19.8 C 4.6 19.3, 3.8 18.2, 3.8 15.5 C 3.6 12, 3.7 8, 4.2 6 C 4.6 4.6, 5.3 4.1, 6.8 4" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" />
