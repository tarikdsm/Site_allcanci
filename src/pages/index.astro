---
import Layout from '../layouts/Layout.astro';
import { getImage } from 'astro:assets';
import { empresa, contatos, redes } from '../data/site';
import { inkInjectorAberta } from '../data/imagens';

const base = import.meta.env.BASE_URL;
const ano = new Date().getFullYear();

const ogImage = await getImage({ src: inkInjectorAberta, format: 'webp', width: 1200 });

const serie1 = [
  {
    num: 'V1',
    slug: 'v1',
    nome: 'Laboratório',
    descricao: 'A máquina como protagonista, no escuro do laboratório.',
    paleta: ['#080808', '#0000fe', '#008aff'],
  },
  {
    num: 'V2',
    slug: 'v2',
    nome: 'Editorial',
    descricao: 'Poppins gigante, grid suíço, confiança institucional.',
    paleta: ['#fefff0', '#080808', '#0000fe'],
  },
  {
    num: 'V3',
    slug: 'v3',
    nome: 'Sala de Aula',
    descricao: 'O site é um quadro branco: traços de marcador ganham vida.',
    paleta: ['#ffffff', '#0000fe', '#ff0c00', '#ffd100'],
  },
  {
    num: 'V4',
    slug: 'v4',
    nome: 'Produto',
    descricao: 'Um scroll, uma história: a recarga em 22 segundos.',
    paleta: ['#ffffff', '#bbe0ef', '#0000fe'],
  },
  {
    num: 'V5',
    slug: 'v5',
    nome: 'Tinta Viva',
    descricao: 'A tinta reage ao seu cursor. O mais ousado.',
    paleta: ['#fefff0', '#0000fe', '#ff0c00', '#080808'],
  },
];

const serie3d = [
  {
    num: 'V6',
    slug: 'v6',
    nome: 'Vitrine',
    descricao: 'A máquina como peça de museu: gire a obra e toque nos detalhes.',
    paleta: ['#0b0b0f', '#e6c87c', '#f6f1e4'],
  },
  {
    num: 'V7',
    slug: 'v7',
    nome: 'Linha de Produção',
    descricao: 'Prancheta de engenharia viva: a máquina gira conforme o scroll.',
    paleta: ['#f3efe4', '#1d3fbf', '#ff5a1f'],
  },
  {
    num: 'V8',
    slug: 'v8',
    nome: 'Quiosque Pop',
    descricao: 'Neo-brutalismo pop: a máquina é o brinquedo da feira.',
    paleta: ['#6c4df6', '#d9ff3f', '#ff7ac3', '#131313'],
  },
  {
    num: 'V9',
    slug: 'v9',
    nome: 'Levitação',
    descricao: 'Vidro, auroras e AR: veja a máquina em tamanho real na sua mesa.',
    paleta: ['#fafbff', '#19c3b1', '#7b8cff', '#ffb2c7'],
  },
  {
    num: 'V10',
    slug: 'v10',
    nome: 'FILL OS',
    descricao: 'O site é o firmware da máquina: boot, terminal e visor com raio-X.',
    paleta: ['#060b1c', '#43e8ff', '#ffc14d'],
  },
];

const serieExperiencias = [
  {
    num: 'V11', slug: 'v11', nome: 'Ciclo Infinito',
    descricao: 'Usar, recarregar e continuar em um circuito visual vivo.',
    paleta: ['#f1efe7', '#0000fe', '#008f4c', '#d7ff54'],
  },
  {
    num: 'V12', slug: 'v12', nome: 'Pitch 90s',
    descricao: 'Uma apresentação imersiva que fala com cada decisor.',
    paleta: ['#0d1026', '#4b5cff', '#ffd100', '#57e5ff'],
  },
  {
    num: 'V13', slug: 'v13', nome: 'Corte o Desperdício',
    descricao: 'Arraste a escola para o lado inteligente da comparação.',
    paleta: ['#dedbd2', '#ff6a3d', '#fefff0', '#0000fe'],
  },
  {
    num: 'V14', slug: 'v14', nome: 'Campus Vivo',
    descricao: 'Explore o ecossistema FILL dentro de uma escola isométrica.',
    paleta: ['#ccecff', '#dfffbd', '#0000fe', '#ffd100'],
  },
  {
    num: 'V15', slug: 'v15', nome: 'Dossiê FILL',
    descricao: 'A decisão institucional organizada em uma pasta viva.',
    paleta: ['#10192f', '#f3ead8', '#1746d1', '#c93832'],
  },
];

const serieDistopia = [
  {
    num: 'V16', slug: 'v16', nome: 'Distopia 2049',
    descricao: 'Cyberpunk distópico: a resistência recarrega em 22 segundos.',
    paleta: ['#05060a', '#00ff60', '#43e8ff', '#ff0c00'],
  },
  {
    num: 'V20', slug: 'v20', nome: 'Noir: Pincel Desaparecido',
    descricao: 'Cinema noir em P&B: a gota azul é a única pista.',
    paleta: ['#0a0a0a', '#f3f3f3', '#0000fe'],
  },
  {
    num: 'V21', slug: 'v21', nome: 'Órbita FILL',
    descricao: 'O sistema FILL como sistema solar: descida do espaço à sala.',
    paleta: ['#030014', '#7b8cff', '#43e8ff', '#fefff0'],
  },
  {
    num: 'V25', slug: 'v25', nome: 'Gazeta de 2050',
    descricao: 'Jornal de 2050: o fim histórico do pincel descartável.',
    paleta: ['#f3efe4', '#080808', '#0000fe', '#ff0c00'],
  },
  {
    num: 'V30', slug: 'v30', nome: 'Universo FILL', tag3d: true,
    descricao: 'O grand finale: a FILL no centro de um universo 3D de tinta.',
    paleta: ['#05060f', '#0000fe', '#43e8ff', '#ffd100'],
  },
];

const serieArte = [
  {
    num: 'V17', slug: 'v17', nome: 'Galeria Tinta Viva',
    descricao: 'Um museu onde a tinta nunca vira lixo.',
    paleta: ['#f6f1e4', '#080808', '#0000fe', '#ff0c00'],
  },
  {
    num: 'V19', slug: 'v19', nome: 'Zine Punk Xerox',
    descricao: 'Colagem xerox punk: papel kraft, carimbos e anti-design.',
    paleta: ['#f3ead8', '#080808', '#ff0c00', '#0000fe'],
  },
  {
    num: 'V22', slug: 'v22', nome: 'Bauhaus Viva',
    descricao: 'Cartaz construtivo: formas primárias que montam o reuso.',
    paleta: ['#f3efe4', '#0000fe', '#ff0c00', '#ffd100'],
  },
  {
    num: 'V26', slug: 'v26', nome: 'Tipografia Cinética',
    descricao: 'A interface são as palavras: tipografia gigante coreografada.',
    paleta: ['#0000fe', '#fefff0', '#ffd100'],
  },
  {
    num: 'V29', slug: 'v29', nome: 'FILL: A Graphic Novel',
    descricao: 'O fim do descartável contado em quadrinhos, quadro a quadro.',
    paleta: ['#fff8e7', '#080808', '#ff0c00', '#0000fe'],
  },
];

const serieMundos = [
  {
    num: 'V18', slug: 'v18', nome: 'Recarga Quest',
    descricao: 'Ficha de arcade 8-bit: aperte start e zere o descarte.',
    paleta: ['#0d0d1f', '#ffd100', '#00ff60', '#ff7ac3'],
  },
  {
    num: 'V23', slug: 'v23', nome: 'Jardim Vivo',
    descricao: 'Recarregar é regenerar: o FILL como um jardim vivo.',
    paleta: ['#f1efe7', '#008f4c', '#00ff60', '#0000fe'],
  },
  {
    num: 'V24', slug: 'v24', nome: 'A Máquina Maravilhosa',
    descricao: 'Steampunk 1889: a FILL como invenção de Jules Verne.',
    paleta: ['#1a120b', '#c98a3d', '#e6c87c', '#f3ead8'],
  },
  {
    num: 'V27', slug: 'v27', nome: 'Fábrica Maluca',
    descricao: 'Máquina Rube Goldberg em SVG que desce pela página.',
    paleta: ['#fefff0', '#0000fe', '#ff6a3d', '#ffd100'],
  },
  {
    num: 'V28', slug: 'v28', nome: 'Oceano de Tinta',
    descricao: 'Mergulhe num mar de tinta até o fim do descartável.',
    paleta: ['#001a33', '#008aff', '#43e8ff', '#bbe0ef'],
  },
];
---

<Layout
  title="Allcanci Tecnologia — 30 propostas para o futuro do site"
  description="Trinta propostas de design para o novo site da Allcanci Tecnologia. Compare V1 a V30: série original, 3D interativo, experiências digitais e as novas séries Distópica, Artística e de Mundos."
  ogImage={ogImage.src}
>
  <div class="pagina">
    <header class="topo">
      <p class="wordmark">allcanci<span> tecnologia</span></p>
    </header>

    <main class="conteudo">
      <section class="hero" aria-labelledby="titulo-hub">
        <p class="etiqueta">30 propostas · 1 decisão</p>
        <h1 id="titulo-hub">Escolha o <span class="destaque">futuro</span> do site da Allcanci</h1>
        <p class="sub">
          Trinta conceitos radicalmente diferentes para o novo site da {empresa.nome}: cinco
          originais, cinco com 3D, cinco experiências interativas e quinze novas fronteiras —
          distópicas, artísticas e lúdicas. Navegue e escolha a direção.
        </p>
      </section>

      <section class="serie" aria-labelledby="titulo-distopia">
        <h2 class="serie-titulo" id="titulo-distopia">
          Série Distópica <span class="serie-badge serie-badge--distopia">novas · futuros possíveis</span>
        </h2>
        <ul class="grade" role="list">
          {
            serieDistopia.map((v) => (
              <li>
                <a class="card" href={`${base}/${v.slug}/`}>
                  <span class="card-topo">
                    <span class="num">{v.num}</span>
                    {v.tag3d && <span class="tag3d">3D</span>}
                    <span class="seta" aria-hidden="true">→</span>
                  </span>
                  <span class="nome">{v.nome}</span>
                  <span class="desc">{v.descricao}</span>
                  <span class="ver">Explorar experiência</span>
                  <span class="paleta" aria-hidden="true">
                    {v.paleta.map((cor) => <span class="cor" style={`background:${cor}`} />)}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="serie" aria-labelledby="titulo-arte">
        <h2 class="serie-titulo" id="titulo-arte">
          Série Artística <span class="serie-badge serie-badge--arte">novas · arte aplicada</span>
        </h2>
        <ul class="grade" role="list">
          {
            serieArte.map((v) => (
              <li>
                <a class="card" href={`${base}/${v.slug}/`}>
                  <span class="card-topo">
                    <span class="num">{v.num}</span>
                    <span class="seta" aria-hidden="true">→</span>
                  </span>
                  <span class="nome">{v.nome}</span>
                  <span class="desc">{v.descricao}</span>
                  <span class="ver">Explorar experiência</span>
                  <span class="paleta" aria-hidden="true">
                    {v.paleta.map((cor) => <span class="cor" style={`background:${cor}`} />)}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="serie" aria-labelledby="titulo-mundos">
        <h2 class="serie-titulo" id="titulo-mundos">
          Série de Mundos <span class="serie-badge serie-badge--mundos">novas · universos imersivos</span>
        </h2>
        <ul class="grade" role="list">
          {
            serieMundos.map((v) => (
              <li>
                <a class="card" href={`${base}/${v.slug}/`}>
                  <span class="card-topo">
                    <span class="num">{v.num}</span>
                    <span class="seta" aria-hidden="true">→</span>
                  </span>
                  <span class="nome">{v.nome}</span>
                  <span class="desc">{v.descricao}</span>
                  <span class="ver">Explorar experiência</span>
                  <span class="paleta" aria-hidden="true">
                    {v.paleta.map((cor) => <span class="cor" style={`background:${cor}`} />)}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="serie" aria-labelledby="titulo-experiencias">
        <h2 class="serie-titulo" id="titulo-experiencias">
          Experiências <span class="serie-badge serie-badge--experiencia">novas · cinco interações autorais</span>
        </h2>
        <ul class="grade" role="list">
          {
            serieExperiencias.map((v) => (
              <li>
                <a class="card" href={`${base}/${v.slug}/`}>
                  <span class="card-topo">
                    <span class="num">{v.num}</span>
                    <span class="tag-interativa">Interativa</span>
                    <span class="seta" aria-hidden="true">→</span>
                  </span>
                  <span class="nome">{v.nome}</span>
                  <span class="desc">{v.descricao}</span>
                  <span class="ver">Explorar experiência</span>
                  <span class="paleta" aria-hidden="true">
                    {v.paleta.map((cor) => <span class="cor" style={`background:${cor}`} />)}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="serie" aria-labelledby="titulo-serie3d">
        <h2 class="serie-titulo" id="titulo-serie3d">
          Série 3D <span class="serie-badge">novas · máquina em 3D interativo</span>
        </h2>
        <ul class="grade" role="list">
          {
            serie3d.map((v) => (
              <li>
                <a class="card" href={`${base}/${v.slug}/`}>
                  <span class="card-topo">
                    <span class="num">{v.num}</span>
                    <span class="tag3d">3D</span>
                    <span class="seta" aria-hidden="true">→</span>
                  </span>
                  <span class="nome">{v.nome}</span>
                  <span class="desc">{v.descricao}</span>
                  <span class="ver">Ver proposta</span>
                  <span class="paleta" aria-hidden="true">
                    {v.paleta.map((cor) => (
                      <span class="cor" style={`background:${cor}`} />
                    ))}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="serie" aria-labelledby="titulo-serie1">
        <h2 class="serie-titulo" id="titulo-serie1">Série original</h2>
        <ul class="grade" role="list">
          {
            serie1.map((v) => (
              <li>
                <a class="card" href={`${base}/${v.slug}/`}>
                  <span class="card-topo">
                    <span class="num">{v.num}</span>
                    <span class="seta" aria-hidden="true">→</span>
                  </span>
                  <span class="nome">{v.nome}</span>
                  <span class="desc">{v.descricao}</span>
                  <span class="ver">Ver proposta</span>
                  <span class="paleta" aria-hidden="true">
                    {v.paleta.map((cor) => (
                      <span class="cor" style={`background:${cor}`} />
                    ))}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>

    <footer class="rodape">
      <div class="rodape-grade">
        <div>
          <p class="rodape-marca">allcanci<span> tecnologia</span></p>
          <p class="rodape-slogan">{empresa.slogan}</p>
        </div>
        <div>
          <h2>Contato</h2>
          <ul role="list">
            <li><a href={`mailto:${contatos.email}`}>{contatos.email}</a></li>
            <li>
              <a href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">
                WhatsApp — {contatos.telefone}
              </a>
            </li>
            <li class="endereco">{contatos.endereco}</li>
          </ul>
        </div>
        <div>
          <h2>Redes</h2>
          <ul role="list">
            {
              redes.map((rede) => (
                <li>
                  <a href={rede.url} target="_blank" rel="noopener noreferrer">
                    {rede.nome}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
      <p class="rodape-nota">© {ano} {empresa.nome} — {empresa.cidade}</p>
    </footer>
  </div>
</Layout>

<style>
  :global(body) {
    background-color: var(--azul);
  }

  .pagina {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: var(--azul);
    background-image:
      radial-gradient(55rem 34rem at 50% -10rem, rgba(0, 138, 255, 0.3), transparent 70%),
      radial-gradient(circle, rgba(254, 255, 240, 0.13) 1px, transparent 1.7px);
    background-repeat: no-repeat, repeat;
    background-size: auto, 28px 28px;
    color: var(--branco);
  }

  /* ── Topo ─────────────────────────────────────────── */
  .topo {
    width: 100%;
    max-width: var(--largura-conteudo);
    margin: 0 auto;
    padding: 2rem clamp(1.25rem, 4vw, 2.5rem) 0;
  }

  .wordmark,
  .rodape-marca {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.35rem;
    letter-spacing: -0.02em;
    color: var(--branco);
  }

  .wordmark span,
  .rodape-marca span {
    font-weight: 500;
    color: var(--nevoa);
  }

  /* ── Hero ─────────────────────────────────────────── */
  .conteudo {
    width: 100%;
    max-width: var(--largura-conteudo);
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem) var(--espaco-secao);
    flex: 1;
  }

  .hero {
    text-align: center;
    padding: clamp(3rem, 8vw, 5.5rem) 0 clamp(2.5rem, 6vw, 4rem);
  }

  .etiqueta {
    display: inline-block;
    margin: 0 0 1.75rem;
    padding: 0.45rem 1.1rem;
    font-family: var(--font-titulo);
    font-weight: 800;
    font-size: var(--texto-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--creme);
    border: 1px solid rgba(254, 255, 240, 0.35);
    border-radius: var(--raio-pill);
  }

  .hero h1 {
    margin: 0 auto;
    max-width: 18ch;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--display-xl);
    line-height: 1.04;
    letter-spacing: -0.03em;
    text-wrap: balance;
    color: var(--branco);
  }

  .destaque {
    color: var(--amarelo);
  }

  .sub {
    max-width: 46rem;
    margin: 1.75rem auto 0;
    font-size: var(--texto-lg);
    line-height: 1.6;
    color: var(--nevoa);
  }

  /* ── Séries ───────────────────────────────────────── */
  .serie {
    margin-top: clamp(2rem, 5vw, 3.5rem);
  }

  .serie:first-of-type {
    margin-top: 0;
  }

  .serie-titulo {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 1.25rem;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--titulo-sm);
    letter-spacing: -0.01em;
    color: var(--branco);
  }

  .serie-badge {
    padding: 0.3rem 0.9rem;
    font-family: var(--font-titulo);
    font-weight: 800;
    font-size: var(--texto-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--preto);
    background: var(--amarelo);
    border-radius: var(--raio-pill);
  }

  .serie-badge--experiencia {
    color: var(--azul-950);
    background: var(--verde);
  }

  .serie-badge--distopia {
    color: var(--branco);
    background: var(--vermelho);
  }

  .serie-badge--arte {
    color: var(--azul-950);
    background: #43e8ff;
  }

  .serie-badge--mundos {
    color: var(--preto);
    background: #ff7ac3;
  }

  /* ── Grade de cards ───────────────────────────────── */
  .grade {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .grade {
      grid-template-columns: repeat(2, 1fr);
    }
    .grade > li:nth-child(5) {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .grade {
      grid-template-columns: repeat(6, 1fr);
    }
    .grade > li {
      grid-column: span 2;
    }
    .grade > li:nth-child(4) {
      grid-column: 2 / span 2;
    }
    .grade > li:nth-child(5) {
      grid-column: span 2;
    }
  }

  .grade > li {
    display: grid;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    height: 100%;
    padding: clamp(1.5rem, 3vw, 2rem);
    background: linear-gradient(180deg, var(--azul-800), var(--azul-950));
    border: 1px solid rgba(254, 255, 240, 0.18);
    border-radius: var(--raio-md);
    color: var(--branco);
    text-decoration: none;
    box-shadow: 0 10px 30px rgba(0, 0, 60, 0.35);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .card:hover {
    transform: translateY(-6px);
    border-color: var(--azul-claro);
    box-shadow:
      0 26px 60px rgba(0, 0, 40, 0.5),
      0 0 0 1px var(--azul-claro);
  }

  .card:focus-visible {
    outline: 3px solid var(--amarelo);
    outline-offset: 4px;
  }

  .card-topo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .card-topo .seta {
    margin-left: auto;
  }

  .tag3d,
  .tag-interativa {
    padding: 0.3rem 0.7rem;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--texto-xs);
    letter-spacing: 0.1em;
    color: var(--preto);
    background: var(--amarelo);
    border-radius: var(--raio-pill);
  }

  .tag-interativa {
    background: var(--verde);
  }

  .num {
    padding: 0.3rem 0.85rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--texto-sm);
    letter-spacing: 0.12em;
    color: var(--creme);
    border: 1px solid rgba(254, 255, 240, 0.3);
    border-radius: var(--raio-pill);
  }

  .seta {
    font-size: 1.35rem;
    color: var(--nevoa);
