---
import Layout from '../../layouts/Layout.astro';
import ExperienceBody from '../../components/ExperienceBody.astro';
import { Image, getImage } from 'astro:assets';
import { empresa, numeros, contatos } from '../../data/site';
import * as img from '../../data/imagens';
import '@fontsource-variable/archivo/index.css';
import '@fontsource-variable/dm-sans/index.css';
import '../../styles/v12.css';

const base = import.meta.env.BASE_URL;
const ogImage = await getImage({ src: img.inkInjectorAberta, format: 'webp', width: 1200 });
const copy = {
  produtosKicker: 'Slide 02 · A solução',
  produtosTitulo: 'Seis peças. Uma decisão simples.',
  produtosTexto: 'O ecossistema completo para recarregar, organizar, controlar e continuar usando.',
  processoKicker: 'Slide 03 · Implantação',
  processoTitulo: 'A Allcanci acompanha do diagnóstico ao dia a dia',
  processoTexto: 'Um roteiro claro, com instalação, treinamento, créditos e suporte contínuo.',
  simuladorKicker: 'Slide 04 · A conta',
  simuladorTitulo: 'Coloque sua escola neste slide',
  simuladorTexto: 'Mude o número de professores. O argumento se atualiza na hora.',
  provaKicker: 'Slide 05 · Tração',
  sustentabilidadeKicker: 'Slide 06 · Impacto',
  faqTexto: 'As perguntas que normalmente aparecem na reunião, respondidas antes do último slide.',
  contatoTitulo: 'Próximo slide: sua escola com FILL',
  contatoTexto: `Fale com a ${empresa.nome}. A equipe transforma este pitch em uma proposta sob medida.`,
};
---

<Layout
  title="Allcanci Pitch 90s — A decisão em movimento"
  description="Uma apresentação interativa do ecossistema FILL para direção, compras e sustentabilidade."
  ogImage={ogImage.src}
  bodyClass="v12"
>
  <a class="v12-skip" href="#hero">Pular para o conteúdo</a>
  <header class="v12-topbar">
    <a class="v12-brand" href={`${base}/`}>ALLCANCI / PITCH 90s</a>
    <p><span data-slide-current>01</span> / 08</p>
    <a href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">FALAR AGORA ↗</a>
  </header>
  <nav class="v12-rail" aria-label="Slides da apresentação">
    <span class="v12-rail-progress" data-pitch-progress></span>
    <a href="#hero" aria-label="Slide 1, abertura">01</a><a href="#produtos" aria-label="Slide 2, produtos">02</a>
    <a href="#como-funciona" aria-label="Slide 3, processo">03</a><a href="#simulador" aria-label="Slide 4, simulador">04</a>
    <a href="#prova-social" aria-label="Slide 5, prova social">05</a><a href="#sustentabilidade" aria-label="Slide 6, sustentabilidade">06</a>
    <a href="#faq" aria-label="Slide 7, perguntas">07</a><a href="#contato" aria-label="Slide 8, contato">08</a>
  </nav>

  <main>
    <section id="hero" class="v12-hero" aria-labelledby="v12-hero-title" data-experience-section>
      <div class="v12-shell v12-hero-layout">
        <div class="v12-hero-copy">
          <p class="v12-eyebrow">Slide 01 · O ponto de virada</p>
          <h1 id="v12-hero-title">22 segundos para mudar a rotina de uma escola.</h1>
          <p class="v12-lead">A principal ferramenta do professor pode ser recarregável, controlável e muito menos descartável.</p>
          <a class="v12-button v12-button-primary" href="#produtos">Começar o pitch <span aria-hidden="true">↓</span></a>
        </div>
        <div class="v12-stage">
          <div class="v12-stage-card">
            <Image src={img.inkInjectorAberta} alt="Máquina FILL Ink Injector aberta" widths={[420, 700, 1000]} sizes="(min-width: 900px) 42vw, 88vw" loading="eager" />
            <p><strong>{numeros.recargaSegundos}s</strong> UMA RECARGA COMPLETA</p>
          </div>
          <div class="v12-persona" aria-label="Escolha a lente da apresentação">
            <p>ESTE PITCH É PARA:</p>
            <div>
              <button type="button" data-persona="direcao" aria-pressed="true">Direção</button>
              <button type="button" data-persona="compras" aria-pressed="false">Compras</button>
              <button type="button" data-persona="sustentabilidade" aria-pressed="false">Sustentabilidade</button>
            </div>
            <p data-persona-panel="direcao">Previsibilidade, suporte e uma rotina de sala mais simples.</p>
            <p data-persona-panel="compras" hidden>Documentação para compras públicas e custo projetado com premissas abertas.</p>
            <p data-persona-panel="sustentabilidade" hidden>Menos pincéis descartados, refil substituível e consumo acompanhado.</p>
          </div>
        </div>
      </div>
      <p class="v12-hint">ROLE, USE ↑ ↓ OU DESLIZE</p>
    </section>
    <ExperienceBody prefix="v12" copy={copy} />
  </main>
  <script src="../../scripts/v12.js"></script>
</Layout>
