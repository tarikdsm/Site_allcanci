---
import Layout from '../../layouts/Layout.astro';
import ExperienceBody from '../../components/ExperienceBody.astro';
import { getImage } from 'astro:assets';
import { empresa, numeros, contatos } from '../../data/site';
import * as img from '../../data/imagens';
import '@fontsource-variable/bricolage-grotesque/index.css';
import '@fontsource-variable/dm-sans/index.css';
import '../../styles/v14.css';

const base = import.meta.env.BASE_URL;
const ogImage = await getImage({ src: img.kitCompleto, format: 'webp', width: 1200 });
const copy = {
  produtosKicker: 'Inventário por ambiente',
  produtosTitulo: 'Cada espaço recebe a parte certa do ecossistema',
  produtosTexto: 'Da ferramenta do professor ao controle da coordenação, tudo conversa dentro da mesma infraestrutura.',
  processoKicker: 'A rota da recarga',
  processoTitulo: 'O pincel sai da sala e volta pronto para continuar',
  processoTexto: 'A implantação conecta diagnóstico, instalação, uso, recarga e gestão com suporte contínuo.',
  simuladorKicker: 'Central de gestão',
  simuladorTitulo: 'Dimensione o campus da sua instituição',
  simuladorTexto: 'Informe professores e visualize a projeção anual do ecossistema FILL.',
  provaKicker: 'Uma rede que já está ativa',
  sustentabilidadeKicker: 'Área verde · menos descarte',
  faqTexto: 'Passe pela central de informações antes de seguir para a portaria.',
  contatoTitulo: 'A portaria para o Campus FILL está aberta',
  contatoTexto: `A ${empresa.nome} atende escolas em todo o Brasil e prepara uma proposta para a sua realidade.`,
};
---

<Layout title="Allcanci Campus Vivo — Uma escola inteira em fluxo" description="Explore um campus interativo e veja como o ecossistema FILL conecta sala, recarga, estoque e gestão." ogImage={ogImage.src} bodyClass="v14">
  <a class="v14-skip" href="#hero">Pular para o conteúdo</a>
  <header class="v14-topbar">
    <a class="v14-brand" href={`${base}/`}>allcanci <span>campus vivo</span></a>
    <p class="v14-status"><i aria-hidden="true"></i> CAMPUS EM OPERAÇÃO</p>
    <a class="v14-top-cta" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Visitar a Allcanci ↗</a>
  </header>
  <main>
    <section id="hero" class="v14-hero" aria-labelledby="v14-hero-title" data-experience-section>
      <div class="v14-shell v14-hero-copy">
        <p class="v14-eyebrow">Infraestrutura inteligente para escolas</p>
        <h1 id="v14-hero-title">Uma escola inteira em fluxo.</h1>
        <p class="v14-lead">Explore o campus. Cada ponto conecta uma decisão, um produto e um ganho para a rotina.</p>
      </div>
      <div class="v14-campus-wrap">
        <div class="v14-campus" data-campus-map data-active-zone="produtos">
          <svg viewBox="0 0 1000 580" role="img" aria-label="Mapa ilustrado de uma escola com sala, coordenação, estoque e ponto de recarga">
            <defs><linearGradient id="v14-ground" x1="0" y1="0" x2="1" y2="1"><stop stop-color="#dfffbd"/><stop offset="1" stop-color="#bde899"/></linearGradient></defs>
            <path d="M100 330 500 90 910 325 510 565Z" fill="url(#v14-ground)" stroke="#202234" stroke-width="4"/>
            <path d="M180 330 475 160 805 350 510 520Z" fill="none" stroke="#fff" stroke-width="24" stroke-linecap="round" stroke-dasharray="12 18"/>
            <g class="v14-building v14-room"><path d="M145 285 320 185 465 270 290 372Z" fill="#fff8e7"/><path d="M290 372V480L465 378V270Z" fill="#d7cdbb"/><path d="M145 285V392L290 480V372Z" fill="#f0dfbd"/><path d="M135 281 318 175 475 266 290 376Z" fill="#0000fe"/></g>
            <g class="v14-building v14-office"><path d="M515 170 650 92 780 168 645 247Z" fill="#fff8e7"/><path d="M645 247V354L780 275V168Z" fill="#ccecff"/><path d="M515 170V278L645 354V247Z" fill="#f0dfbd"/><path d="M505 166 649 82 790 164 645 251Z" fill="#ffd100"/></g>
            <g class="v14-building v14-stock"><path d="M610 340 760 253 885 326 735 414Z" fill="#fff8e7"/><path d="M735 414V505L885 417V326Z" fill="#c7bca6"/><path d="M610 340V431L735 505V414Z" fill="#eee0c4"/><path d="M600 336 759 243 895 322 735 418Z" fill="#ff4b3e"/></g>
            <g class="v14-station"><path d="M390 300 500 236 610 300 500 365Z" fill="#202234"/><path d="M430 297 500 257 570 297 500 338Z" fill="#0000fe"/><circle cx="500" cy="297" r="24" fill="#57e5ff"/></g>
            <g class="v14-trees" fill="#008f4c"><circle cx="180" cy="450" r="35"/><circle cx="835" cy="220" r="32"/><circle cx="410" cy="500" r="28"/></g>
            <path class="v14-route" d="M300 370C360 345 415 335 498 300S640 285 720 340" fill="none" stroke="#ff4b3e" stroke-width="8" stroke-linecap="round" stroke-dasharray="2 18"/>
          </svg>
          <button class="v14-hotspot v14-hotspot-room" type="button" data-campus-target="produtos"><span>01</span>Sala de aula</button>
          <button class="v14-hotspot v14-hotspot-station" type="button" data-campus-target="como-funciona"><span>02</span>Ponto de recarga</button>
          <button class="v14-hotspot v14-hotspot-office" type="button" data-campus-target="simulador"><span>03</span>Coordenação</button>
          <button class="v14-hotspot v14-hotspot-stock" type="button" data-campus-target="sustentabilidade"><span>04</span>Estoque circular</button>
          <div class="v14-campus-legend" aria-hidden="true"><b>{numeros.escolas}</b> ESCOLAS JÁ CONECTADAS</div>
        </div>
      </div>
      <nav class="v14-mobile-route" aria-label="Destinos do campus"><a href="#produtos">Sala</a><a href="#como-funciona">Recarga</a><a href="#simulador">Gestão</a><a href="#sustentabilidade">Impacto</a></nav>
    </section>
    <ExperienceBody prefix="v14" copy={copy} />
  </main>
  <script src="../../scripts/v14.js"></script>
</Layout>
