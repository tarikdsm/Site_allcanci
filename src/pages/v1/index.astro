---
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { empresa, numeros, contatos, redes } from '../../data/site';
import { produtos } from '../../data/produtos';
import { etapasComodato } from '../../data/comodato';
import { faq } from '../../data/faq';
import { provaSocial } from '../../data/provaSocial';
import { sustentabilidade } from '../../data/sustentabilidade';
import * as img from '../../data/imagens';
import { simular, reais, PREMISSAS } from '../../scripts/simulador-core.js';
import '../../styles/v1.css';

const base = import.meta.env.BASE_URL;
const ano = new Date().getFullYear();

// Estado inicial do simulador (renderizado no servidor para funcionar sem JS)
const professoresIniciais = 20;
const sim0 = simular(professoresIniciais);

// Stats neon do hero — valores vindos de src/data/site.ts
const stats = [
  { valor: numeros.escolas.replace(/\D/g, ''), prefixo: '+', sufixo: '', texto: numeros.escolas, rotulo: 'escolas já atendidas' },
  { valor: String(numeros.recargaSegundos), prefixo: '', sufixo: 's', texto: `${numeros.recargaSegundos}s`, rotulo: 'por recarga automática' },
  { valor: String(numeros.escritaKm), prefixo: '', sufixo: ' km', texto: `${numeros.escritaKm} km`, rotulo: 'de escrita por recarga' },
  { valor: String(numeros.entregaDiasUteis), prefixo: '', sufixo: '', texto: String(numeros.entregaDiasUteis), rotulo: 'dias úteis até a entrega' },
];

// Fotos dos produtos — todas exibidas sobre estágio claro (xadrez gravado seguro)
const fotosProdutos: Record<string, { src: ImageMetadata; alt: string }> = {
  'ink-injector': {
    src: img.inkInjector,
    alt: 'Máquina FILL Ink Injector vista de frente, com encaixes de recarga nas cores azul, preto e vermelho e visor digital aceso',
  },
  'eco-marker': {
    src: img.ecoMarkerTrio,
    alt: 'Três pincéis recarregáveis FILL Eco Marker nas cores vermelho, preto e azul',
  },
  'master-color': {
    src: img.masterColorTrio,
    alt: 'Três frascos de 500 ml de tinta FILL Master Color nas cores azul, vermelho e preto',
  },
  'master-clean': {
    src: img.masterClean,
    alt: 'Estojo apagador FILL Master Clean 3P na cor azul, com feltro apagador na base',
  },
  refil: {
    src: img.ecoMarkerPreto,
    alt: 'Pincel FILL Eco Marker preto com refil de feltro removível translúcido encaixado na base',
  },
  app: {
    src: img.moedasCredito,
    alt: 'Três moedas azuis de crédito de recarga FILL com gota de tinta em relevo',
  },
};

const linksMenu = [
  { href: '#produtos', rotulo: 'Produtos' },
  { href: '#como-funciona', rotulo: 'Como funciona' },
  { href: '#simulador', rotulo: 'Simulador' },
  { href: '#sustentabilidade', rotulo: 'Sustentabilidade' },
  { href: '#faq', rotulo: 'FAQ' },
  { href: '#contato', rotulo: 'Contato' },
];

const telefoneHref = `tel:+55${contatos.telefone.replace(/\D/g, '')}`;
---

<Layout
  title="Allcanci Tecnologia — Recarga inteligente para quadro branco"
  description={empresa.descricao}
  bodyClass="v1"
>
  <a class="v1-skip" href="#hero">Pular para o conteúdo</a>

  <header class="v1-topo">
    <div class="v1-caixa v1-topo-linha">
      <a class="v1-wordmark" href="#hero">
        <span class="v1-pulso" aria-hidden="true"></span>
        allcanci<span>&nbsp;tecnologia</span>
      </a>
      <nav class="v1-nav" aria-label="Seções da página">
        <ul class="v1-menu" role="list">
          {linksMenu.map((item) => (
            <li><a href={item.href}>{item.rotulo}</a></li>
          ))}
        </ul>
      </nav>
      <a
        class="v1-botao v1-botao--primario v1-botao--mini"
        href={contatos.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
        </svg>
        WhatsApp
      </a>
    </div>
  </header>

  <main>
    <!-- ═══ HERO ═══ -->
    <section id="hero" class="v1-hero" aria-labelledby="titulo-hero">
      <div class="v1-caixa v1-hero-conteudo">
        <p class="v1-kicker">{empresa.nome} · {empresa.cidade}</p>
        <h1 id="titulo-hero">
          A <span class="v1-grifo">recarga inteligente</span> que o quadro branco esperava
        </h1>
        <p class="v1-sub">{empresa.descricao}</p>

        <div class="v1-hero-ctas">
          <a
            class="v1-botao v1-botao--primario"
            href={contatos.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
            </svg>
            Falar no WhatsApp
          </a>
          <a class="v1-botao v1-botao--fantasma" href="#simulador">Simular a economia</a>
        </div>

        <div class="v1-estagio-wrap">
          <div class="v1-estagio" data-tilt>
            <span class="v1-badge">
              <span class="v1-pulso" aria-hidden="true"></span>
              {numeros.recargaSegundos}s por recarga
            </span>
            <Image
              src={img.inkInjector}
              alt={fotosProdutos['ink-injector']!.alt}
              widths={[420, 640, 900, 1240]}
              sizes="(min-width: 800px) 40rem, 88vw"
              loading="eager"
            />
            <span class="v1-estagio-legenda">FILL Ink Injector</span>
          </div>
        </div>

        <ul class="v1-stats" role="list">
          {stats.map((stat) => (
            <li class="v1-stat">
              <span
                class="v1-stat-num"
                data-contador={stat.valor}
                data-prefixo={stat.prefixo}
                data-sufixo={stat.sufixo}
              >{stat.texto}</span>
              <span class="v1-stat-rotulo">{stat.rotulo}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ═══ PRODUTOS ═══ -->
    <section id="produtos" class="v1-secao v1-secao--respiro" aria-labelledby="titulo-produtos">
      <div class="v1-caixa">
        <p class="v1-kicker">Ecossistema FILL</p>
        <h2 class="v1-titulo" id="titulo-produtos">Seis peças, um laboratório completo</h2>
        <p class="v1-sub">
          Da máquina de recarga ao aplicativo de gestão: cada componente foi projetado para
          funcionar em conjunto — e acabar com o pincel descartável.
        </p>

        <ul class="v1-produtos-grade" role="list">
          {produtos.map((produto) => {
            const foto = fotosProdutos[produto.id];
            return (
              <li class="v1-produto">
                {foto && (
                  <div class="v1-produto-foto">
                    <Image
                      src={foto.src}
                      alt={foto.alt}
                      widths={[320, 480, 680]}
                      sizes="(min-width: 1024px) 340px, (min-width: 640px) 46vw, 88vw"
                    />
                  </div>
                )}
                <span class="v1-produto-tag">{produto.subtitulo}</span>
                <h3>{produto.nome}</h3>
                <p class="v1-produto-desc">{produto.descricao}</p>
                <ul class="v1-destaques" role="list">
                  {produto.destaques.map((destaque) => (
                    <li>{destaque}</li>
                  ))}
                </ul>
              </li>
            );
          })}
        </ul>
      </div>
    </section>

    <!-- ═══ COMO FUNCIONA ═══ -->
    <section id="como-funciona" class="v1-secao" aria-labelledby="titulo-como">
      <div class="v1-caixa">
        <p class="v1-kicker">Comodato em 6 etapas</p>
        <h2 class="v1-titulo" id="titulo-como">Do diagnóstico à recarga contínua</h2>
        <p class="v1-sub">
          Sem investimento inicial em equipamento: a Allcanci instala, treina e acompanha —
          sua equipe só usa.
        </p>

        <div class="v1-como-grade">
          <ol class="v1-etapas" role="list">
            {etapasComodato.map((etapa, i) => (
              <li class="v1-etapa">
                <span class="v1-etapa-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <h3>{etapa.titulo}</h3>
                <p>{etapa.texto}</p>
              </li>
            ))}
          </ol>

          <aside class="v1-como-aside" aria-label="Como recarregar um pincel">
            <div class="v1-estagio v1-estagio--aside">
              <Image
                src={img.comoUsar}
                alt="Ilustração da recarga em três passos: primeiro, insira o pincel no encaixe da máquina e a tampa na trava de segurança; depois, aguarde 22 segundos para a recarga; por fim, retire o pincel e a tampa e utilize normalmente."
                widths={[420, 640, 900]}
                sizes="(min-width: 1024px) 26rem, 88vw"
              />
              <span class="v1-estagio-legenda">A recarga em 3 passos</span>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ═══ SIMULADOR ═══ -->
    <section id="simulador" class="v1-secao v1-secao--respiro" aria-labelledby="titulo-simulador">
      <div class="v1-caixa">
        <p class="v1-kicker">Simulador de economia</p>
        <h2 class="v1-titulo" id="titulo-simulador">Quanto a sua instituição economiza?</h2>
        <p class="v1-sub">
          Arraste o controle do console e veja a projeção anual em tempo real — recargas,
          custos e plástico que deixa de virar lixo.
        </p>

        <div class="v1-console">
          <div class="v1-console-topo" aria-hidden="true">
            <span class="v1-console-luz"></span>
            <span class="v1-console-luz"></span>
            <span class="v1-console-luz"></span>
            <p class="v1-console-titulo">console · economia anual</p>
          </div>
          <div class="v1-console-corpo">
            <div>
              <label class="v1-console-label" for="sim-professores">
                Professores na instituição
              </label>
              <div class="v1-console-controle-linha">
                <input
                  type="range"
                  id="sim-professores"
                  min="1"
                  max="200"
                  step="1"
                  value={professoresIniciais}
                />
                <input
                  type="number"
                  id="sim-professores-num"
                  min="1"
                  max="999"
                  value={professoresIniciais}
                  aria-label="Número de professores"
                />
              </div>
              <p class="v1-premissas">
                Premissas do cálculo: {PREMISSAS.recargasPorProfessorAno} recargas por
                professor/ano · crédito de recarga a {reais(PREMISSAS.precoCreditoReais)} · 1
                recarga rende ~{PREMISSAS.kmPorRecarga} km de escrita · pincel descartável rende
                ~{PREMISSAS.metrosPorDescartavel} m e custa {reais(PREMISSAS.precoDescartavelReais)} ·
                ~{PREMISSAS.kgPlasticoPorDescartavel * 1000} g de plástico por descartável.
              </p>
            </div>

            <dl class="v1-leituras">
              <div class="v1-leitura">
                <dt>Recargas por ano</dt>
                <dd id="sim-recargas">{sim0.recargasAno.toLocaleString('pt-BR')}</dd>
              </div>
              <div class="v1-leitura">
                <dt>Investimento FILL/ano</dt>
                <dd id="sim-custo-fill">{reais(sim0.custoFill)}</dd>
              </div>
              <div class="v1-leitura">
                <dt>Descartáveis evitados</dt>
                <dd id="sim-descartaveis">{sim0.descartaveis.toLocaleString('pt-BR')}</dd>
              </div>
              <div class="v1-leitura">
                <dt>Plástico evitado</dt>
                <dd id="sim-plastico">{sim0.plasticoEvitadoKg.toLocaleString('pt-BR')} kg</dd>
              </div>
              <div class="v1-leitura v1-leitura--destaque">
                <dt>Economia estimada/ano</dt>
                <dd id="sim-economia">{reais(sim0.economia)}</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PROVA SOCIAL ═══ -->
    <section id="prova-social" class="v1-secao" aria-labelledby="titulo-prova">
      <div class="v1-caixa">
        <p class="v1-kicker">Confiança</p>
        <h2 class="v1-titulo" id="titulo-prova">{provaSocial.titulo}</h2>
        <p class="v1-sub">{provaSocial.texto}</p>

        <ul class="v1-selos" role="list">
          {provaSocial.selos.map((selo) => (
            <li class="v1-selo">
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="8.6" stroke="currentColor" stroke-width="1.5" />
                <path d="m6.2 10.3 2.5 2.5 5.1-5.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              {selo}
            </li>
          ))}
        </ul>

        {provaSocial.depoimentos.length > 0 && (
          <ul class="v1-depoimentos" role="list">
            {provaSocial.depoimentos.map((dep) => (
              <li>
                <blockquote>
                  <p>{dep.citacao}</p>
                  <footer>
                    {dep.autor} — {dep.instituicao}
                  </footer>
                </blockquote>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

    <!-- ═══ SUSTENTABILIDADE ═══ -->
    <section id="sustentabilidade" class="v1-secao" aria-labelledby="titulo-sustentabilidade">
      <div class="v1-caixa">
        <p class="v1-kicker v1-kicker--verde">Sustentabilidade</p>
        <h2 class="v1-titulo" id="titulo-sustentabilidade">{sustentabilidade.titulo}</h2>
        <p class="v1-sub">{sustentabilidade.texto}</p>

        <ul class="v1-verde-grade" role="list">
          {sustentabilidade.pontos.map((ponto) => (
            <li class="v1-verde-card">
              <h3>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 19C5 10 10 5 19 5c0 9-5 14-14 14Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                  <path d="M5 19c3-5.5 6.5-9 10-10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                </svg>
                {ponto.titulo}
              </h3>
              <p>{ponto.texto}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ═══ FAQ ═══ -->
    <section id="faq" class="v1-secao" aria-labelledby="titulo-faq">
      <div class="v1-caixa">
        <p class="v1-kicker">FAQ</p>
        <h2 class="v1-titulo" id="titulo-faq">Perguntas frequentes</h2>
        <p class="v1-sub">
          O que escolas e instituições mais perguntam antes de adotar o ecossistema FILL.
        </p>

        <div class="v1-faq-lista">
          {faq.map((item) => (
            <details>
              <summary>
                {item.pergunta}
                <span class="v1-faq-mais" aria-hidden="true">+</span>
              </summary>
              <p class="v1-faq-resposta">{item.resposta}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ CONTATO ═══ -->
    <section id="contato" class="v1-secao" aria-labelledby="titulo-contato">
      <div class="v1-caixa">
        <div class="v1-contato-card">
          <h2 id="titulo-contato">Leve o laboratório FILL para a sua instituição</h2>
          <p>
            Fale com a equipe da {empresa.nome} e receba uma proposta de comodato sob medida —
            entrega em até {numeros.entregaDiasUteis} dias úteis para todo o Brasil.
          </p>

          <div class="v1-contato-cta">
            <a
              class="v1-botao v1-botao--branco"
              href={contatos.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M21 12a8.5 8.5 0 0 1-12.4 7.5L3 21l1.6-5.2A8.5 8.5 0 1 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
              </svg>
              Chamar no WhatsApp
            </a>
          </div>

          <ul class="v1-contato-lista" role="list">
            <li>
              <a class="v1-chip" href={`mailto:${contatos.email}`}>{contatos.email}</a>
            </li>
            <li>
              <a class="v1-chip" href={telefoneHref}>{contatos.telefone}</a>
            </li>
          </ul>

          <address>{contatos.endereco}</address>

          <ul class="v1-contato-redes" role="list">
            {redes.map((rede) => (
              <li>
                <a class="v1-chip" href={rede.url} target="_blank" rel="noopener noreferrer">
                  {rede.nome}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </main>

  <footer class="v1-rodape">
    <div class="v1-caixa">
      <div class="v1-rodape-grade">
        <div>
          <p class="v1-rodape-marca">allcanci<span>&nbsp;tecnologia</span></p>
          <p class="v1-rodape-slogan">{empresa.slogan}. {empresa.descricao}</p>
        </div>
        <div>
          <h2>Contato</h2>
          <ul role="list">
            <li><a href={`mailto:${contatos.email}`}>{contatos.email}</a></li>
            <li>
              <a href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">
                WhatsApp — {contatos.telefone}
              </a>
            </li>
            <li>{contatos.endereco}</li>
          </ul>
        </div>
        <div>
          <h2>Redes</h2>
          <ul role="list">
            {redes.map((rede) => (
              <li>
                <a href={rede.url} target="_blank" rel="noopener noreferrer">{rede.nome}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <div class="v1-rodape-nota">
        <p>© {ano} {empresa.nome} — {empresa.cidade}</p>
        <p><a href={`${base}/`}>Ver as 5 propostas de design</a></p>
      </div>
    </div>
  </footer>

  <script src="../../scripts/v1.js"></script>
</Layout>
