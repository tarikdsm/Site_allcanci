---
import Layout from '../../layouts/Layout.astro';
import ExperienceBody from '../../components/ExperienceBody.astro';
import { Image, getImage } from 'astro:assets';
import { empresa, numeros, contatos, diferenciais } from '../../data/site';
import * as img from '../../data/imagens';
import '@fontsource-variable/bricolage-grotesque/index.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/700.css';
import '../../styles/v19.css';

const base = import.meta.env.BASE_URL;
const ogImage = await getImage({ src: img.inkInjectorAberta, format: 'webp', width: 1200 });
const ticker = 'RECARREGUE ★ NÃO DESCARTE ★ 22 SEGUNDOS POR RECARGA ★ PATENTEADA ★ 100% NACIONAL ★ +500 ESCOLAS ★ ';
const copy = {
  produtosKicker: 'O arsenal anti-descarte',
  produtosTitulo: 'Seis peças. Zero lixo.',
  produtosTexto: 'Máquina, pincel, tinta, apagador, refil e créditos: um sistema fechado, desenhado para o pincel nunca mais parar no lixo.',
  processoKicker: 'Como entra na sua escola',
  processoTitulo: 'Comodato: a máquina fica, a burocracia some',
  processoTexto: 'A Allcanci dimensiona, instala, treina e acompanha. Sua escola só se preocupa em usar — e em recarregar em 22 segundos.',
  simuladorKicker: 'Conta de padaria, sem letra miúda',
  simuladorTitulo: 'Quanto sua escola joga fora por ano?',
  simuladorTexto: 'Arraste o número de professores e veja a projeção anual: recargas, economia e o plástico que deixa de ir para o lixo.',
  provaKicker: 'Quem já colou nessa',
  sustentabilidadeKicker: 'Menos lixo, mais aula',
  faqTexto: 'As perguntas que todo mundo faz antes de aposentar o descartável — respondidas sem rodeio.',
  contatoTitulo: 'Cole sua escola nesse cartaz.',
  contatoTexto: `Chame a ${empresa.nome} no WhatsApp e receba uma proposta dimensionada para a sua instituição.`,
};
---

<Layout
  title="Allcanci Zine Punk — Recarrega, não joga fora"
  description="O ecossistema FILL em versão zine xerocado: colagem analógica, papel kraft, carimbos e a máquina que recarrega pincéis de quadro branco em 22 segundos."
  ogImage={ogImage.src}
  bodyClass="v19"
>
  <a class="v19-skip" href="#hero">Pular para o conteúdo</a>

  <svg class="v19-defs" width="0" height="0" aria-hidden="true" focusable="false">
    <defs>
      <filter id="v19-rough">
        <feTurbulence type="fractalNoise" baseFrequency="0.035" numOctaves="4" seed="7" result="noise" />
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="3.5" />
      </filter>
    </defs>
  </svg>

  <header class="v19-topbar">
    <a class="v19-brand" href={`${base}/`} aria-label="Allcanci — voltar às propostas">allcanci<span>tecnologia</span></a>
    <nav aria-label="Navegação principal">
      <a href="#manifesto">Manifesto</a><a href="#produtos">Arsenal</a><a href="#simulador">A conta</a><a href="#contato">Contato</a>
    </nav>
    <a class="v19-mini-cta" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">WhatsApp ↗</a>
  </header>

  <main>
    <section id="hero" class="v19-hero" aria-labelledby="v19-hero-title" data-experience-section>
      <div class="v19-shell v19-hero-grid">
        <div class="v19-hero-copy">
          <p class="v19-kicker">Edição nº 22 · o fim do descartável</p>
          <h1 id="v19-hero-title" class="v19-h1">
            <span class="v19-h1-line">Recarrega,</span>
            <span class="v19-h1-line v19-h1-mark">não joga</span>
            <span class="v19-h1-line">fora.</span>
          </h1>
          <p class="v19-hero-lead">A FILL Ink Injector, da Allcanci Tecnologia (Betim/MG), recarrega pincel de quadro branco em 22 segundos. Patenteada, 100% nacional e única no mundo — um zine inteiro não daria conta do lixo que ela evita.</p>
          <div class="v19-actions">
            <a class="v19-button v19-button-primary" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Chamar no WhatsApp <span aria-hidden="true">↗</span></a>
            <a class="v19-button" href="#produtos">Ver o arsenal <span aria-hidden="true">↓</span></a>
          </div>
          <ul class="v19-hero-stats" role="list">
            <li><strong>{numeros.recargaSegundos}s</strong><span>por recarga</span></li>
            <li><strong>{numeros.escolas}</strong><span>escolas no ciclo</span></li>
            <li><strong>{numeros.escritaKm} km</strong><span>de escrita por carga</span></li>
          </ul>
        </div>

        <div class="v19-collage">
          <figure class="v19-photo v19-photo-main">
            <Image src={img.inkInjectorAberta} alt="Máquina FILL Ink Injector aberta, pronta para receber um pincel de quadro branco" widths={[420, 640, 900]} sizes="(min-width: 960px) 42vw, 88vw" loading="eager" />
          </figure>
          <span class="v19-note" aria-hidden="true">22 segundos<br />e tá novo!</span>
          <svg class="v19-arrow" viewBox="0 0 160 90" aria-hidden="true" focusable="false">
            <g fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 76 C 36 30, 80 12, 130 34" stroke-width="5" />
              <path d="M112 20 L 132 36 L 106 46" stroke-width="5" />
              <path d="M12 78 C 38 32, 82 14, 132 36" stroke-width="2" opacity=".35" />
            </g>
          </svg>
          <svg class="v19-stamp" viewBox="0 0 200 200" role="img" aria-label="Carimbo: patenteada, única no mundo">
            <defs>
              <path id="v19-stamp-arc" d="M100,100 m-74,0 a74,74 0 1,1 148,0 a74,74 0 1,1 -148,0" />
            </defs>
            <circle cx="100" cy="100" r="90" class="v19-stamp-ring" />
            <circle cx="100" cy="100" r="58" class="v19-stamp-ring v19-stamp-ring-in" />
            <text class="v19-stamp-text"><textPath href="#v19-stamp-arc">PATENTEADA ★ ÚNICA NO MUNDO ★ FILL ★</textPath></text>
            <text x="100" y="98" text-anchor="middle" class="v19-stamp-fill">FILL</text>
            <text x="100" y="122" text-anchor="middle" class="v19-stamp-seg">22 seg</text>
          </svg>
          <span class="v19-stamp-rect" aria-hidden="true">100% nacional</span>
          <figure class="v19-photo v19-photo-mini">
            <Image src={img.kitCompleto} alt="Kit completo do ecossistema FILL: máquina, pincéis, tintas e apagador" widths={[220, 340]} sizes="(min-width: 720px) 180px, 34vw" loading="lazy" />
          </figure>
        </div>
      </div>
      <div class="v19-ticker" aria-hidden="true"><span>{ticker}{ticker}</span></div>
    </section>

    <section id="manifesto" class="v19-section v19-manifesto" aria-labelledby="v19-manifesto-title" data-experience-section>
      <div class="v19-shell">
        <p class="v19-eyebrow">Manifesto de fábrica</p>
        <h2 class="v19-title" id="v19-manifesto-title">Cinco verdades pregadas na parede</h2>
        <p class="v19-lead">O que segura cada máquina que sai de Betim — sem asterisco, sem pegadinha.</p>
        <ul class="v19-manifesto-grid" role="list">
          {diferenciais.map((item, index) => (
            <li class="v19-manifesto-card">
              <span class="v19-manifesto-num" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <h3>{item.titulo}</h3>
              <p>{item.texto}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <ExperienceBody prefix="v19" copy={copy} />
  </main>
  <script src="../../scripts/v19.js"></script>
</Layout>
