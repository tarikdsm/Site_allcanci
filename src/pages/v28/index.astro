---
import Layout from '../../layouts/Layout.astro';
import ExperienceBody from '../../components/ExperienceBody.astro';
import { Image, getImage } from 'astro:assets';
import { empresa, numeros, contatos } from '../../data/site';
import maquinaRender from '../../assets/3d/maquina-fill-render.png';
import maquinaPerfil from '../../assets/3d/maquina-fill-perfil.png';
import '@fontsource-variable/space-grotesk/index.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/700.css';
import '../../styles/v28.css';

const base = import.meta.env.BASE_URL;
const ogImage = await getImage({ src: maquinaRender, format: 'webp', width: 1200 });
const escolasNumero = numeros.escolas.replace('+', '');
const copy = {
  produtosKicker: 'A tripulação do mergulho',
  produtosTitulo: 'Seis peças do mesmo mar',
  produtosTexto: 'Máquina, pincel, tinta, apagador, refil e aplicativo navegam juntos: um ecossistema desenhado para circular — nunca para afundar no lixo.',
  processoKicker: 'Rota de descida',
  processoTitulo: 'Do primeiro contato ao mergulho contínuo',
  processoTexto: 'A Allcanci dimensiona, instala, treina e acompanha. Sua escola desce com segurança — e nunca fica sem ar.',
  simuladorKicker: 'Sonar de economia',
  simuladorTitulo: 'Meça a profundidade da sua economia',
  simuladorTexto: 'Ajuste o número de professores e veja a projeção anual com as premissas abertas.',
  provaKicker: 'Quem já mergulha com a FILL',
  sustentabilidadeKicker: 'Maré limpa',
  faqTexto: 'Tudo o que sua instituição precisa saber antes de mergulhar no ecossistema FILL.',
  contatoTitulo: 'Ancore a FILL na sua escola',
  contatoTexto: `Converse com a ${empresa.nome} e receba uma proposta dimensionada para a sua instituição.`,
};
---

<Layout
  title="Allcanci Oceano de Tinta — Mergulhe até o fim do descartável"
  description="Um mergulho vertical pelo ecossistema FILL: desça 1000 metros de tinta e descubra a máquina que recarrega pincéis de quadro branco em 22 segundos."
  ogImage={ogImage.src}
  bodyClass="v28"
>
  <a class="v28-skip" href="#hero">Pular para o conteúdo</a>

  <canvas class="v28-bubbles" data-v28-bubbles aria-hidden="true"></canvas>
  <div class="v28-darkness" aria-hidden="true"></div>
  <div class="v28-rays" aria-hidden="true"></div>

  <aside class="v28-depth" aria-hidden="true">
    <p class="v28-depth-read"><output data-v28-depth-value>0000</output><span class="v28-depth-unit">m</span></p>
    <p class="v28-depth-caption">metros de tinta</p>
    <div class="v28-depth-track">
      <span class="v28-depth-fill" data-v28-depth-fill></span>
      <span class="v28-depth-tick" style="--tick: 0%"><i>0 m · superfície</i></span>
      <span class="v28-depth-tick" style="--tick: 2.2%"><i>22 m · 22 s de recarga</i></span>
      <span class="v28-depth-tick" style="--tick: 50%"><i>500 m · +500 escolas</i></span>
      <span class="v28-depth-tick" style="--tick: 100%"><i>1000 m · 1 km de escrita</i></span>
    </div>
    <p class="v28-depth-zone" data-v28-depth-zone>Superfície</p>
  </aside>

  <header class="v28-topbar">
    <a class="v28-brand" href={`${base}/`} aria-label="Allcanci — voltar às propostas">allcanci<span>tecnologia</span></a>
    <nav aria-label="Navegação principal">
      <a href="#produtos">Ecossistema</a><a href="#como-funciona">Comodato</a><a href="#simulador">Economia</a><a href="#contato">Contato</a>
    </nav>
    <a class="v28-mini-cta" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Conversar ↗</a>
  </header>

  <main class="v28-main">
    <section id="hero" class="v28-hero" aria-labelledby="v28-hero-title" data-experience-section>
      <div class="v28-surface" aria-hidden="true">
        <svg class="v28-wave v28-wave-a" viewBox="0 0 1440 120" preserveAspectRatio="none"><path d="M0,46 C240,96 480,6 720,46 C960,86 1200,12 1440,46 L1440,0 L0,0 Z" /></svg>
        <svg class="v28-wave v28-wave-b" viewBox="0 0 1440 120" preserveAspectRatio="none"><path d="M0,30 C260,80 520,0 780,34 C1040,68 1240,8 1440,30 L1440,0 L0,0 Z" /></svg>
      </div>

      <div class="v28-shell v28-hero-grid">
        <div class="v28-hero-copy">
          <p class="v28-eyebrow">Superfície · 0 m de tinta</p>
          <h1 id="v28-hero-title">Mergulhe no <em>oceano de tinta</em>.</h1>
          <p class="v28-lead">Role para afundar. A cada metro de descida, um número real do ecossistema FILL — a tecnologia de Betim/MG que recarrega pincéis de quadro branco em {numeros.recargaSegundos} segundos, em comodato para escolas.</p>
          <div class="v28-actions">
            <a class="v28-button v28-button-primary" href="#produtos">Iniciar o mergulho <span aria-hidden="true">↓</span></a>
            <a class="v28-button" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Falar com a Allcanci <span aria-hidden="true">↗</span></a>
          </div>
          <ul class="v28-depthmarks" role="list">
            <li><strong>{numeros.recargaSegundos} m</strong><span>= {numeros.recargaSegundos} s por recarga</span></li>
            <li><strong>{escolasNumero} m</strong><span>= {numeros.escolas} escolas a bordo</span></li>
            <li><strong>1000 m</strong><span>= {numeros.escritaKm} km de escrita por recarga</span></li>
          </ul>
        </div>

        <div class="v28-hero-visual" data-v28-float="0.08">
          <div class="v28-hero-bob">
            <span class="v28-hero-ring" aria-hidden="true"></span>
            <span class="v28-hero-ring v28-hero-ring-b" aria-hidden="true"></span>
            <Image src={maquinaRender} alt="Máquina FILL Ink Injector flutuando sob a superfície de um mar de tinta azul" widths={[420, 640, 900]} sizes="(min-width: 900px) 36vw, 78vw" loading="eager" />
          </div>
        </div>
      </div>

      <a class="v28-dive-cue" href="#produtos" aria-label="Descer para o ecossistema FILL">
        <span>a correnteza leva</span>
        <b aria-hidden="true">↓</b>
      </a>
    </section>

    <ExperienceBody prefix="v28" copy={copy} />

    <section id="fundo-do-oceano" class="v28-floor" aria-labelledby="v28-floor-title" data-experience-section>
      <div class="v28-shell v28-floor-grid">
        <div class="v28-floor-copy">
          <p class="v28-eyebrow">Fundo do oceano · 1000 m</p>
          <h2 id="v28-floor-title">Você chegou ao fundo. <em>A tinta continua.</em></h2>
          <p class="v28-lead">Aqui embaixo não existe lixo: só a Ink Injector ancorada, pronta para a próxima recarga de {numeros.recargaSegundos} segundos.</p>
          <div class="v28-actions">
            <a class="v28-button v28-button-primary" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Trazer a FILL para minha escola <span aria-hidden="true">↗</span></a>
            <a class="v28-button" href="#hero">Subir à superfície <span aria-hidden="true">↑</span></a>
          </div>
        </div>
        <div class="v28-floor-visual" data-v28-float="0.06">
          <Image src={maquinaPerfil} alt="Máquina FILL Ink Injector de perfil, ancorada no fundo do oceano de tinta" widths={[360, 560, 800]} sizes="(min-width: 900px) 32vw, 72vw" loading="lazy" />
          <svg class="v28-anchor" viewBox="0 0 64 64" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round">
              <circle cx="32" cy="10" r="6" />
              <path d="M32 16v34M18 26h28M12 38c0 12 9 18 20 18s20-6 20-18M12 38l-5 6M12 38l6 5M52 38l5 6M52 38l-6 5" />
            </g>
          </svg>
        </div>
      </div>
      <div class="v28-sand" aria-hidden="true"></div>
    </section>
  </main>
  <script src="../../scripts/v28.js"></script>
</Layout>
