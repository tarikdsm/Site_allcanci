---
import Layout from '../../layouts/Layout.astro';
import ExperienceBody from '../../components/ExperienceBody.astro';
import { Image, getImage } from 'astro:assets';
import { empresa, numeros, contatos } from '../../data/site';
import { produtos } from '../../data/produtos';
import renderFrontal from '../../assets/3d/maquina-fill-render.png';
import renderPerfil from '../../assets/3d/maquina-fill-perfil.png';
import renderTopo from '../../assets/3d/maquina-fill-topo.png';
import renderTqDir from '../../assets/3d/maquina-fill-tq-dir.png';
import '@fontsource-variable/space-grotesk/index.css';
import '../../styles/v30.css';

const base = import.meta.env.BASE_URL;
const glbUrl = `${base}/models/maquina_fill_web.glb`;
const ogImage = await getImage({ src: renderFrontal, format: 'webp', width: 1200 });

const copy = {
  produtosKicker: 'Capítulo 03 · O inventário orbital',
  produtosTitulo: 'Seis corpos celestes, um único sistema',
  produtosTexto:
    'Máquina, pincel, tinta, apagador, refil e aplicativo: cada peça orbita a mesma missão — nunca mais jogar um pincel fora.',
  processoKicker: 'Capítulo 04 · A órbita do comodato',
  processoTitulo: 'Uma rota de aproximação sem turbulência',
  processoTexto:
    'A Allcanci dimensiona, instala, treina e acompanha. A escola entra em órbita estável, com suporte em cada volta.',
  simuladorKicker: 'Capítulo 05 · Cálculo estelar',
  simuladorTitulo: 'Meça a massa do que sua escola deixa de jogar fora',
  simuladorTexto:
    'Ajuste o número de professores e veja a projeção anual de recargas, economia e plástico evitado — com as premissas abertas.',
  provaKicker: 'Capítulo 06 · Sinais de vida',
  sustentabilidadeKicker: 'Capítulo 07 · O planeta agradece',
  faqTexto: 'As transmissões mais frequentes de quem está prestes a entrar em órbita — respondidas sem rodeios.',
  contatoTitulo: 'Inicie a contagem para a sua escola',
  contatoTexto: `Fale com a ${empresa.nome} e receba uma proposta de comodato dimensionada para a sua instituição.`,
};
---

<Layout
  title="Allcanci Universo FILL — O grand finale da recarga"
  description="Uma viagem cinematográfica pelo ecossistema FILL: a máquina Ink Injector flutuando entre milhares de partículas de tinta, enquanto o scroll coreografa a câmera pelos capítulos da recarga inteligente."
  ogImage={ogImage.src}
  bodyClass="v30"
>
  <a class="v30-skip" href="#hero">Pular para o conteúdo</a>

  <!-- Palco cinematográfico: canvas three.js fixo em tela cheia.
       Sob ele ficam a nebulosa CSS e o pôster estático (fallback de
       reduced-motion, mobile fraco ou falha de WebGL). -->
  <div class="v30-palco" aria-hidden="true">
    <div class="v30-nebulosa"></div>
    <div class="v30-poster">
      <Image
        src={renderFrontal}
        alt=""
        widths={[460, 760, 1100]}
        sizes="(min-width: 900px) 52vw, 92vw"
        loading="eager"
      />
    </div>
    <canvas class="v30-canvas" data-glb={glbUrl}></canvas>
  </div>

  <div class="v30-trilha" aria-hidden="true"><span class="v30-trilha-barra"></span></div>
  <p class="v30-hud" aria-hidden="true"><span class="v30-hud-cap">CAP. 01/10</span><span class="v30-hud-nome">PRÓLOGO</span></p>

  <header class="v30-topbar">
    <a class="v30-brand" href={`${base}/`} aria-label="Allcanci — voltar às propostas">
      allcanci<span>universo fill</span>
    </a>
    <nav aria-label="Capítulos">
      <a href="#gravidade">Gravidade</a>
      <a href="#produtos">Inventário</a>
      <a href="#simulador">Cálculo</a>
      <a href="#contato">Contato</a>
    </nav>
    <a class="v30-mini-cta" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Transmissão ↗</a>
  </header>

  <main>
    <!-- ═══ PRÓLOGO ═══ -->
    <section id="hero" class="v30-hero" aria-labelledby="v30-hero-title" data-experience-section>
      <div class="v30-hero-copy">
        <p class="v30-eyebrow">{empresa.nome} apresenta · o grand finale</p>
        <h1 id="v30-hero-title">O universo <em>FILL</em></h1>
        <p class="v30-lead">
          Uma máquina no centro. Milhares de partículas de tinta em órbita.
          E o fim do pincel descartável — em {numeros.recargaSegundos} segundos por recarga.
        </p>
        <div class="v30-actions">
          <a class="v30-button v30-button-primary" href="#gravidade">Atravessar o universo <span aria-hidden="true">↓</span></a>
          <a class="v30-button" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Falar com a Allcanci <span aria-hidden="true">↗</span></a>
        </div>
      </div>
      <p class="v30-scroll-hint" aria-hidden="true"><span></span>role para iniciar a viagem</p>
    </section>

    <!-- ═══ CAP. 01 · GRAVIDADE ═══ -->
    <section id="gravidade" class="v30-capitulo" aria-labelledby="v30-gravidade-title" data-experience-section>
      <div class="v30-shell v30-capitulo-grid">
        <div>
          <p class="v30-eyebrow">Capítulo 01 · Gravidade</p>
          <h2 id="v30-gravidade-title">No centro deste universo, <em>uma máquina</em>.</h2>
          <p class="v30-capitulo-texto">
            A FILL Ink Injector é o corpo celeste que dá massa ao sistema: tecnologia 100% nacional
            e patenteada, única no mundo, que recarrega pincéis de quadro branco de forma automática,
            precisa e sem sujeira. Tudo o que existe em volta — pincéis, tintas, créditos — orbita
            em função dela.
          </p>
        </div>
        <ul class="v30-leis" role="list">
          <li><strong>{numeros.recargaSegundos}s</strong><span>para uma recarga completa, sem abrir o pincel</span></li>
          <li><strong>{numeros.escritaKm} km</strong><span>de escrita contínua por recarga</span></li>
          <li><strong>{numeros.escolas}</strong><span>escolas já em órbita pelo Brasil</span></li>
        </ul>
      </div>
    </section>

    <!-- ═══ CAP. 02 · CONSTELAÇÃO ═══ -->
    <section id="constelacao" class="v30-capitulo" aria-labelledby="v30-constelacao-title" data-experience-section>
      <div class="v30-shell">
        <p class="v30-eyebrow">Capítulo 02 · Constelação</p>
        <h2 id="v30-constelacao-title">Seis peças em <em>órbita síncrona</em>.</h2>
        <p class="v30-capitulo-texto v30-capitulo-texto-largo">
          Nenhum componente existe sozinho. O ecossistema FILL foi desenhado como uma constelação:
          cada peça tem seu lugar, sua função e seu tempo — e juntas aposentam o descarte.
        </p>
        <ul class="v30-astros" role="list">
          {produtos.map((produto, index) => (
            <li>
              <a href="#produtos">
                <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
                {produto.nome}
              </a>
            </li>
          ))}
        </ul>
        <div class="v30-satelites" aria-hidden="true">
          <figure class="v30-satelite v30-satelite-a">
            <Image src={renderPerfil} alt="" widths={[220, 340]} sizes="(min-width: 720px) 18vw, 34vw" loading="lazy" />
          </figure>
          <figure class="v30-satelite v30-satelite-b">
            <Image src={renderTopo} alt="" widths={[200, 300]} sizes="(min-width: 720px) 15vw, 30vw" loading="lazy" />
          </figure>
          <figure class="v30-satelite v30-satelite-c">
            <Image src={renderTqDir} alt="" widths={[240, 360]} sizes="(min-width: 720px) 20vw, 36vw" loading="lazy" />
          </figure>
        </div>
      </div>
    </section>

    <ExperienceBody prefix="v30" copy={copy} />
  </main>

  <script src="../../scripts/v30.js"></script>
</Layout>
