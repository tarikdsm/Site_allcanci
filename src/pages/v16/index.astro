---
import Layout from '../../layouts/Layout.astro';
import ExperienceBody from '../../components/ExperienceBody.astro';
import { Image, getImage } from 'astro:assets';
import { empresa, numeros, contatos, diferenciais } from '../../data/site';
import * as img from '../../data/imagens';
import maquinaRender from '../../assets/3d/maquina-fill-render.png';
import '@fontsource/chakra-petch/400.css';
import '@fontsource/chakra-petch/600.css';
import '@fontsource/chakra-petch/700.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '@fontsource/ibm-plex-mono/700.css';
import '../../styles/v16.css';

const base = import.meta.env.BASE_URL;
const ogImage = await getImage({ src: img.ecoMarkerTrioTampas, format: 'webp', width: 1200 });
const copy = {
  produtosKicker: 'O arsenal da resistência',
  produtosTitulo: 'Equipamento de quem se recusa a descartar',
  produtosTexto: 'Máquina, pincel, tinta, apagador, refil e aplicativo: o kit completo que mantém a escrita viva num mundo que jogou tudo fora.',
  processoKicker: 'Protocolo de recrutamento',
  processoTitulo: 'Como sua escola entra na resistência',
  processoTexto: 'A Allcanci dimensiona, instala, treina e acompanha. O comodato é o canal seguro: nenhuma escola fica para trás.',
  simuladorKicker: 'Meça o estrago evitado',
  simuladorTitulo: 'Quantos descartáveis sua escola deixa de soterrar?',
  simuladorTexto: 'Arraste o número de professores e veja a projeção anual: plástico que não vira montanha, verba que não vira fumaça.',
  provaKicker: 'A rede já está ativa',
  sustentabilidadeKicker: 'O plano de descontaminação',
  faqTexto: 'Perguntas capturadas na frequência aberta, respondidas pela central Allcanci.',
  contatoTitulo: 'Abra um canal com a resistência',
  contatoTexto: `Fale com a ${empresa.nome} e receba uma proposta dimensionada para sua instituição. A transmissão é segura — e o futuro agradece.`,
};
---

<Layout
  title="Allcanci Distopia 2049 — A resistência recarrega"
  description="2049: montanhas de pincéis descartáveis soterram a cidade. A Allcanci é a resistência — recarga em 22 segundos, comodato para escolas, zero descarte."
  ogImage={ogImage.src}
  bodyClass="v16"
>
  <a class="v16-skip" href="#hero">Pular para o conteúdo</a>
  <header class="v16-topbar">
    <a class="v16-brand" href={`${base}/`} aria-label="Allcanci — voltar às propostas">ALLCANCI<span>//resistência</span></a>
    <nav aria-label="Navegação principal">
      <a href="#produtos">Arsenal</a><a href="#como-funciona">Protocolo</a><a href="#simulador">Impacto</a><a href="#contato">Canal</a>
    </nav>
    <a class="v16-mini-cta" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Transmitir ↗</a>
  </header>

  <main>
    <section id="hero" class="v16-hero" aria-labelledby="v16-hero-title" data-experience-section>
      <canvas class="v16-rain" data-rain aria-hidden="true"></canvas>
      <div class="v16-shell v16-hero-grid">
        <div class="v16-hero-copy">
          <p class="v16-alarm">▲ ALERTA // NÍVEL DE DESCARTE: CRÍTICO</p>
          <p class="v16-hero-eyebrow">TRANSMISSÃO INTERCEPTADA · ANO 2049 · CANAL 22</p>
          <h1 id="v16-hero-title" class="v16-glitch">
            <span class="v16-glitch-base">Eles enterraram o futuro. <em>Nós recarregamos.</em></span>
            <span class="v16-glitch-layer" aria-hidden="true">Eles enterraram o futuro. Nós recarregamos.</span>
            <span class="v16-glitch-layer v16-glitch-layer-b" aria-hidden="true">Eles enterraram o futuro. Nós recarregamos.</span>
          </h1>
          <p class="v16-hero-lead">2049. Montanhas de pincéis descartáveis soterram o que restou das cidades. A resposta da resistência cabe em 22 segundos: o ecossistema FILL recarrega, reutiliza e prova que nenhum pincel precisa morrer.</p>
          <div class="v16-actions">
            <a class="v16-button v16-button-primary" href="#produtos">Ver o arsenal <span aria-hidden="true">▸</span></a>
            <a class="v16-button" href="#simulador">Simular o impacto</a>
          </div>
          <ul class="v16-hero-stats" role="list">
            <li><strong>{numeros.recargaSegundos}s</strong><span>por recarga</span></li>
            <li><strong>{numeros.escolas}</strong><span>escolas na rede</span></li>
            <li><strong>{numeros.escritaKm} km</strong><span>de escrita por carga</span></li>
          </ul>
        </div>

        <div class="v16-holo">
          <p class="v16-holo-tag">UNIDADE FILL // INK INJECTOR</p>
          <div class="v16-holo-frame">
            <Image src={maquinaRender} alt="Máquina FILL Ink Injector em render 3D, projetada como holograma" widths={[420, 640, 900]} sizes="(min-width: 1000px) 38vw, 84vw" loading="eager" />
            <span class="v16-holo-scan" aria-hidden="true"></span>
          </div>
          <p class="v16-holo-chip"><b>22s</b> · ciclo completo de recarga</p>
        </div>
      </div>
    </section>

    <div class="v16-ticker" aria-hidden="true"><span>NENHUM PINCEL A MENOS ◆ 22 SEGUNDOS ◆ RECARREGAR É RESISTIR ◆ FILL // ALLCANCI ◆ NENHUM PINCEL A MENOS ◆ 22 SEGUNDOS ◆ RECARREGAR É RESISTIR ◆ FILL // ALLCANCI ◆ </span></div>

    <section class="v16-section v16-transmissions" aria-labelledby="v16-trans-title">
      <div class="v16-shell">
        <p class="v16-eyebrow">Arquivo da resistência</p>
        <h2 class="v16-title" id="v16-trans-title">Registros interceptados</h2>
        <p class="v16-lead">Fragmentos recuperados da frequência aberta. Cada registro é uma razão para continuar.</p>
        <ol class="v16-logs" role="list">
          {diferenciais.map((registro, index) => (
            <li class="v16-log">
              <p class="v16-log-id">[REG.{String(index + 1).padStart(3, '0')} // SINAL ESTÁVEL]</p>
              <h3>{registro.titulo}</h3>
              <p>{registro.texto}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <ExperienceBody prefix="v16" copy={copy} />
  </main>
  <div class="v16-scanlines" aria-hidden="true"></div>
  <div class="v16-vignette" aria-hidden="true"></div>
  <script src="../../scripts/v16.js"></script>
</Layout>
