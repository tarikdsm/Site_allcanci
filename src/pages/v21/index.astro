---
import Layout from '../../layouts/Layout.astro';
import ExperienceBody from '../../components/ExperienceBody.astro';
import { Image, getImage } from 'astro:assets';
import { empresa, numeros, contatos } from '../../data/site';
import * as img from '../../data/imagens';
import maquinaFillRender from '../../assets/3d/maquina-fill-render.png';
import '@fontsource-variable/space-grotesk/index.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/600.css';
import '../../styles/v21.css';

const base = import.meta.env.BASE_URL;
const ogImage = await getImage({ src: img.kitCompleto, format: 'webp', width: 1200 });
const copy = {
  produtosKicker: 'Fase 01 — Órbita FILL',
  produtosTitulo: 'Seis corpos celestes, um só sistema',
  produtosTexto:
    'Ao centro, a Ink Injector. Em volta, pincel, tinta, apagador, refil e créditos: cada produto ocupa a sua órbita e mantém o sistema girando sem descarte.',
  processoKicker: 'Fase 02 — Acoplagem',
  processoTitulo: 'Do primeiro contato à órbita estável',
  processoTexto:
    'A Allcanci dimensiona, entrega, instala e treina. Sua escola acopla no ecossistema FILL com suporte durante toda a missão.',
  simuladorKicker: 'Fase 03 — Telemetria',
  simuladorTitulo: 'Dados de voo da sua economia',
  simuladorTexto:
    'Ajuste o número de professores e leia o painel: recargas, descartáveis evitados e o plástico que deixa de virar detrito espacial.',
  provaKicker: 'Fase 04 — Constelação de escolas',
  sustentabilidadeKicker: 'Missão sustentável',
  faqTexto: 'Perguntas frequentes de quem está prestes a embarcar na missão FILL.',
  contatoTitulo: 'Aterrissagem autorizada',
  contatoTexto: `Fale com a ${empresa.nome} e traga o sistema FILL para a órbita da sua escola.`,
};
---

<Layout
  title="Allcanci Órbita FILL — O sistema solar do quadro branco"
  description="O ecossistema FILL como sistema solar: role para descer do espaço profundo até a sala de aula e conhecer a recarga de pincéis em 22 segundos."
  ogImage={ogImage.src}
  bodyClass="v21"
>
  <a class="v21-skip" href="#hero">Pular para o conteúdo</a>

  <div class="v21-nebula v21-nebula-a" data-v21-nebula aria-hidden="true"></div>
  <div class="v21-nebula v21-nebula-b" data-v21-nebula aria-hidden="true"></div>
  <canvas class="v21-stars" data-v21-stars aria-hidden="true"></canvas>

  <header class="v21-topbar">
    <a class="v21-brand" href={`${base}/`} aria-label="Allcanci — voltar às propostas">allcanci<span>tecnologia</span></a>
    <nav aria-label="Navegação principal">
      <a href="#produtos">Órbita</a><a href="#mapa">Plano de voo</a><a href="#simulador">Telemetria</a><a href="#contato">Pouso</a>
    </nav>
    <a class="v21-mini-cta" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Base Allcanci ↗</a>
  </header>

  <aside class="v21-telemetry" aria-label="Telemetria da missão">
    <p class="v21-telemetry-title">Telemetria <span class="v21-blink" aria-hidden="true">●</span></p>
    <dl>
      <div><dt>Recarga</dt><dd>22 s</dd></div>
      <div><dt>Escolas</dt><dd>+500</dd></div>
      <div><dt>Escrita</dt><dd>1 km</dd></div>
      <div><dt>Economia</dt><dd data-v21-economia>R$ —</dd></div>
      <div><dt>Altitude</dt><dd data-v21-altitude>400 km</dd></div>
    </dl>
    <div class="v21-alt-track" aria-hidden="true"><span data-v21-alt-bar></span></div>
  </aside>

  <main>
    <section id="hero" class="v21-hero" aria-labelledby="v21-hero-title" data-experience-section>
      <div class="v21-shell v21-hero-grid">
        <div class="v21-hero-copy">
          <p class="v21-eyebrow">Transmissão 001 · Espaço profundo</p>
          <h1 id="v21-hero-title">O quadro branco tem seu próprio <em>sistema solar</em>.</h1>
          <p class="v21-lead">
            No centro, a Ink Injector recarrega um pincel em 22 segundos. Em órbita, os produtos que impedem
            sua escola de jogar outro pincel fora. Role para descer do espaço profundo até a sala de aula.
          </p>
          <div class="v21-actions">
            <a class="v21-button v21-button-primary" href="#mapa">Iniciar descida <span aria-hidden="true">↓</span></a>
            <a class="v21-button" href="#simulador">Ir à telemetria</a>
          </div>
          <ul class="v21-hero-stats" role="list">
            <li><strong>{numeros.recargaSegundos} s</strong><span>por recarga</span></li>
            <li><strong>{numeros.escolas}</strong><span>escolas em órbita</span></li>
            <li><strong>{numeros.escritaKm} km</strong><span>de escrita por carga</span></li>
          </ul>
        </div>

        <div class="v21-system" data-v21-system role="img" aria-label="Sistema solar FILL: a máquina Ink Injector é o sol central e os produtos Eco Marker, Master Color e Master Clean orbitam como planetas">
          <div class="v21-sun">
            <Image src={maquinaFillRender} alt="" widths={[300, 480, 700]} sizes="(min-width: 920px) 20vw, 42vw" loading="eager" />
          </div>
          <div class="v21-orbit v21-orbit-a">
            <div class="v21-spin v21-spin-a"><span class="v21-planet v21-planet-color"></span></div>
          </div>
          <div class="v21-orbit v21-orbit-b">
            <div class="v21-spin v21-spin-b"><span class="v21-planet v21-planet-eco"></span></div>
          </div>
          <div class="v21-orbit v21-orbit-c">
            <div class="v21-spin v21-spin-c"><span class="v21-planet v21-planet-clean"></span></div>
            <div class="v21-spin v21-spin-c2"><span class="v21-planet v21-planet-moon"></span></div>
          </div>
        </div>
      </div>

      <ul class="v21-legend v21-shell" role="list" aria-label="Legenda dos planetas">
        <li><i class="v21-dot v21-dot-eco" aria-hidden="true"></i>Eco Marker — o pincel</li>
        <li><i class="v21-dot v21-dot-color" aria-hidden="true"></i>Master Color — a tinta</li>
        <li><i class="v21-dot v21-dot-clean" aria-hidden="true"></i>Master Clean — o apagador</li>
        <li><i class="v21-dot v21-dot-moon" aria-hidden="true"></i>Refil + créditos — as luas</li>
      </ul>

      <div class="v21-asteroid" aria-hidden="true">
        <svg viewBox="0 0 240 130">
          <path class="v21-trail" d="M8 118 C 60 96, 110 84, 158 66" />
          <g>
            <polygon points="150,38 182,24 214,40 222,72 204,100 168,102 146,76" fill="#4a4360" stroke="#6f6890" stroke-width="2" />
            <polygon points="168,52 184,44 198,56 192,74 174,76 162,64" fill="#5d567a" opacity=".8" />
            <circle cx="205" cy="82" r="6" fill="#39334e" />
            <g transform="rotate(-32 190 40)">
              <rect x="166" y="30" width="52" height="13" rx="6.5" fill="#c9cede" />
              <rect x="212" y="30" width="14" height="13" rx="6" fill="#8f96ad" />
              <path d="M166 33 L158 36.5 L166 40 Z" fill="#8f96ad" />
            </g>
          </g>
        </svg>
        <p>último pincel descartável avistado<br /><span>em rota de extinção · sem retorno</span></p>
      </div>

      <div class="v21-ticker" aria-hidden="true">
        <span>RECARGA EM 22 S ✦ +500 ESCOLAS ✦ 1 KM DE ESCRITA ✦ ZERO DESCARTE ✦ RECARGA EM 22 S ✦ +500 ESCOLAS ✦ 1 KM DE ESCRITA ✦ ZERO DESCARTE ✦ RECARGA EM 22 S ✦ +500 ESCOLAS ✦ 1 KM DE ESCRITA ✦ ZERO DESCARTE ✦ RECARGA EM 22 S ✦ +500 ESCOLAS ✦ 1 KM DE ESCRITA ✦ ZERO DESCARTE ✦&nbsp;</span>
      </div>
    </section>

    <section id="mapa" class="v21-section v21-map" aria-labelledby="v21-map-title" data-experience-section>
      <div class="v21-shell">
        <p class="v21-eyebrow">Plano de voo</p>
        <h2 class="v21-title" id="v21-map-title">Da órbita à sala de aula</h2>
        <p class="v21-lead">Quatro fases separam a sua escola do fim do descartável. Siga a constelação.</p>
        <ol class="v21-constellation" role="list">
          <li><a href="#produtos"><b>01</b><span>Órbita FILL</span><small>o ecossistema completo</small></a></li>
          <li><a href="#como-funciona"><b>02</b><span>Acoplagem</span><small>o comodato passo a passo</small></a></li>
          <li><a href="#simulador"><b>03</b><span>Telemetria</span><small>o impacto em números</small></a></li>
          <li><a href="#contato"><b>04</b><span>Aterrissagem</span><small>sua escola na Terra</small></a></li>
        </ol>
      </div>
    </section>

    <ExperienceBody prefix="v21" copy={copy} />
  </main>
  <script src="../../scripts/v21.js"></script>
</Layout>
