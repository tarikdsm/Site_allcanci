---
import '@fontsource-variable/space-grotesk/index.css';
import Layout from '../../layouts/Layout.astro';
import ExperienceBody from '../../components/ExperienceBody.astro';
import { getImage } from 'astro:assets';
import { empresa, numeros, contatos } from '../../data/site';
import * as img from '../../data/imagens';
import '../../styles/v26.css';

const base = import.meta.env.BASE_URL;
const ogImage = await getImage({ src: img.kitCompleto, format: 'webp', width: 1200 });
const fotoTinta = await getImage({ src: img.ecoMarkerTrioTampas, format: 'webp', width: 1200 });
const foto22 = await getImage({ src: img.comoUsar, format: 'webp', width: 1200 });

const copy = {
  produtosKicker: 'Seis peças, um verbo só: continuar',
  produtosTitulo: 'Seis peças. Um ciclo.',
  produtosTexto: 'Máquina, pincel, tinta, apagador, refil e créditos — cada palavra desse ecossistema termina na mesma frase: nada vai para o lixo.',
  processoKicker: 'Comodato, sem letra miúda',
  processoTitulo: 'Do diagnóstico ao suporte contínuo.',
  processoTexto: 'A Allcanci dimensiona, instala, treina e acompanha. A escola escreve; o ciclo gira.',
  simuladorKicker: 'Faça as contas em voz alta',
  simuladorTitulo: 'Os números gritam.',
  simuladorTexto: 'Arraste o número de professores e veja, em tipografia grande, o que sua escola economiza e deixa de jogar fora por ano.',
  provaKicker: 'Quem já escreve esse futuro',
  sustentabilidadeKicker: 'Menos lixo, mais letra',
  faqTexto: 'As perguntas que sempre aparecem no quadro — respondidas sem rodeio.',
  contatoTitulo: 'A próxima palavra é sua.',
  contatoTexto: `Converse com a ${empresa.nome} e receba uma proposta de comodato dimensionada para a sua escola.`,
};
---

<Layout
  title="Allcanci Tipografia Cinética — Tinta sem fim"
  description="O ecossistema FILL recarrega pincéis de quadro branco em 22 segundos. Uma experiência em que a interface é a palavra."
  ogImage={ogImage.src}
  bodyClass="v26"
>
  <a class="v26-skip" href="#hero">Pular para o conteúdo</a>
  <header class="v26-topbar">
    <a class="v26-brand" href={`${base}/`} aria-label="Allcanci — voltar às propostas">allcanci<sup>®</sup></a>
    <nav aria-label="Navegação principal">
      <a href="#produtos">Sistema</a><a href="#simulador">Números</a><a href="#contato">Contato</a>
    </nav>
    <a class="v26-mini-cta" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Falar ↗</a>
  </header>

  <main>
    <section id="hero" class="v26-hero" aria-labelledby="v26-hero-title" data-experience-section>
      <p class="v26-hero-eyebrow" data-kinetic>Recarga inteligente para quadro branco — {empresa.cidade}</p>
      <h1 id="v26-hero-title" class="v26-hero-title">
        <span class="v26-line" data-kinetic><span class="v26-photo-text" style={`--foto-letra: url('${fotoTinta.src}')`}>TINTA</span></span>
        <span class="v26-line v26-line-indent" data-kinetic style="--d:.12s">SEM</span>
        <span class="v26-line" data-kinetic style="--d:.24s">FIM.</span>
      </h1>
      <p class="v26-hero-lead" data-kinetic style="--d:.34s">A máquina FILL recarrega o pincel do quadro branco em {numeros.recargaSegundos} segundos. Usar, apagar, recarregar — a escrita nunca para.</p>
      <div class="v26-hero-actions" data-kinetic style="--d:.44s">
        <a class="v26-button v26-button-primary" href="#produtos">Ver o sistema <span aria-hidden="true">↓</span></a>
        <a class="v26-button" href={contatos.whatsappUrl} target="_blank" rel="noopener noreferrer">Falar com a Allcanci <span aria-hidden="true">↗</span></a>
      </div>
      <dl class="v26-hero-stats" data-kinetic style="--d:.54s">
        <div><dt>por recarga</dt><dd>{numeros.recargaSegundos}<span>s</span></dd></div>
        <div><dt>escolas atendidas</dt><dd>{numeros.escolas}</dd></div>
        <div><dt>de escrita por recarga</dt><dd>{numeros.escritaKm}<span>&nbsp;km</span></dd></div>
      </dl>
    </section>

    <div class="v26-marquee" aria-hidden="true">
      <div class="v26-marquee-track">
        <span>USAR ● APAGAR ● RECARREGAR ● RECOMEÇAR ●&nbsp;</span>
        <span>USAR ● APAGAR ● RECARREGAR ● RECOMEÇAR ●&nbsp;</span>
      </div>
    </div>

    <section class="v26-fala" aria-labelledby="v26-fala-title" data-experience-section>
      <h2 id="v26-fala-title" class="visually-hidden">Do vazio ao cheio em 22 segundos</h2>
      <p class="v26-fala-eyebrow" data-kinetic>do vazio ao cheio em</p>
      <p class="v26-fala-num" data-kinetic style="--d:.1s">
        <span class="v26-photo-text" style={`--foto-letra: url('${foto22.src}')`}>22</span><span class="v26-fala-unit">segundos</span>
      </p>
      <p class="v26-fala-words">
        <span data-drift="-1">usar.</span>
        <span data-drift="1.2">apagar.</span>
        <span data-drift="-1.6">recarregar.</span>
        <span class="v26-fala-hl" data-drift="2">recomeçar.</span>
      </p>
    </section>

    <div class="v26-marquee v26-marquee-alt" aria-hidden="true">
      <div class="v26-marquee-track">
        <span>+500 ESCOLAS ● 22 SEGUNDOS ● ZERO DESCARTE ●&nbsp;</span>
        <span>+500 ESCOLAS ● 22 SEGUNDOS ● ZERO DESCARTE ●&nbsp;</span>
      </div>
    </div>

    <ExperienceBody prefix="v26" copy={copy} />
  </main>
  <script src="../../scripts/v26.js"></script>
</Layout>
